<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme (VS Code Dark Modern palette) -->
    <Color x:Key="BgDark">#1E1E1E</Color>
    <Color x:Key="BgPanel">#1E1E1E</Color>
    <Color x:Key="BgHeader">#252526</Color>
    <Color x:Key="BgHover">#2A2D2E</Color>
    <Color x:Key="Surface">#252526</Color>
    <Color x:Key="SurfaceHover">#2D2D2D</Color>
    <Color x:Key="SurfaceLight">#333334</Color>
    <Color x:Key="SurfaceDeep">#1E1E1E</Color>
    <Color x:Key="Overlay">#8011141A</Color>
    <Color x:Key="Accent">#0078D4</Color>
    <Color x:Key="AccentHover">#1A8AFF</Color>
    <Color x:Key="AccentSoft">#4DA6FF</Color>
    <Color x:Key="AccentDim">#0078D433</Color>
    <Color x:Key="AccentGlow">#0078D433</Color>
    <Color x:Key="AccentSecondary">#4EC9B0</Color>
    <Color x:Key="AccentTertiary">#4ECF6E</Color>
    <Color x:Key="FgLight">#D4D4D4</Color>
    <Color x:Key="FgDim">#9DA0A6</Color>
    <Color x:Key="FgMuted">#878787</Color>
    <Color x:Key="Border">#2B2B2B</Color>
    <Color x:Key="BorderMuted">#252526</Color>
    <Color x:Key="BorderFocus">#0078D4</Color>
    <Color x:Key="PanelBorder">#2B2B2B44</Color>
    <Color x:Key="Selection">#3378D455</Color>
    <Color x:Key="SelectionActive">#5578D488</Color>
    <Color x:Key="Ok">#4ECF6E</Color>
    <Color x:Key="Warn">#E4A615</Color>
    <Color x:Key="Err">#F14C4C</Color>
    <Color x:Key="DiffAdd">#4ECF6E</Color>
    <Color x:Key="DiffAddBg">#4ECF6E12</Color>
    <Color x:Key="DiffDel">#F14C4C</Color>
    <Color x:Key="DiffDelBg">#F14C4C12</Color>
    <Color x:Key="DiffMod">#E4A615</Color>
    <Color x:Key="DiffModBg">#E4A61516</Color>
    <Color x:Key="DiffHunk">#569CD6</Color>
    <Color x:Key="DiffMeta">#C586C0</Color>
    <Color x:Key="DiffFile">#4EC9B0</Color>
    <Color x:Key="RowAltColor">#12161F</Color>
    <Color x:Key="TitleBarGradientTopColor">#3C3C3C</Color>
    <Color x:Key="EditorSelectionBorder">#1E4060</Color>
    <Color x:Key="EditorCurrentLine">#2B2B2B</Color>
    <Color x:Key="EditorGutterBg">#1E1E1E</Color>
    <Color x:Key="EditorScrollbarBg">#1E1E1E</Color>
    <Color x:Key="EditorScrollbarThumb">#424242</Color>
    <Color x:Key="EditorScrollbarThumbHover">#555555</Color>
    <Color x:Key="GlassOverlay">#1E1E1EE0</Color>
    <Color x:Key="MenuBg">#252526</Color>
    <Color x:Key="TitleBarBg">#323233</Color>
    <Color x:Key="AppTitleColor">#FFFFFF</Color>
    <Color x:Key="AppSubtitleColor">#9A9EB0</Color>

    <SolidColorBrush x:Key="BgDarkBrush" Color="{DynamicResource BgDark}"/>
    <SolidColorBrush x:Key="BgPanelBrush" Color="{DynamicResource BgPanel}"/>
    <SolidColorBrush x:Key="BgHeaderBrush" Color="{DynamicResource BgHeader}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{DynamicResource BgHover}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource Surface}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{DynamicResource SurfaceHover}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{DynamicResource SurfaceLight}"/>
    <SolidColorBrush x:Key="SurfaceDeepBrush" Color="{DynamicResource SurfaceDeep}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource Overlay}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHover}"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoft}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{DynamicResource AccentDim}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{DynamicResource AccentGlow}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{DynamicResource AccentSecondary}"/>
    <SolidColorBrush x:Key="AccentTertiaryBrush" Color="{DynamicResource AccentTertiary}"/>
    <SolidColorBrush x:Key="FgLightBrush" Color="{DynamicResource FgLight}"/>
    <SolidColorBrush x:Key="FgDimBrush" Color="{DynamicResource FgDim}"/>
    <SolidColorBrush x:Key="FgMutedBrush" Color="{DynamicResource FgMuted}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource Border}"/>
    <SolidColorBrush x:Key="BorderMutedBrush" Color="{DynamicResource BorderMuted}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{DynamicResource BorderFocus}"/>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{DynamicResource PanelBorder}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{DynamicResource Selection}"/>
    <SolidColorBrush x:Key="SelectionActiveBrush" Color="{DynamicResource SelectionActive}"/>
    <SolidColorBrush x:Key="DiffAddBrush" Color="{DynamicResource DiffAdd}"/>
    <SolidColorBrush x:Key="DiffAddBgBrush" Color="{DynamicResource DiffAddBg}"/>
    <SolidColorBrush x:Key="DiffDelBrush" Color="{DynamicResource DiffDel}"/>
    <SolidColorBrush x:Key="DiffDelBgBrush" Color="{DynamicResource DiffDelBg}"/>
    <SolidColorBrush x:Key="DiffModBrush" Color="{DynamicResource DiffMod}"/>
    <SolidColorBrush x:Key="DiffModBgBrush" Color="{DynamicResource DiffModBg}"/>
    <SolidColorBrush x:Key="DiffHunkBrush" Color="{DynamicResource DiffHunk}"/>
    <SolidColorBrush x:Key="DiffMetaBrush" Color="{DynamicResource DiffMeta}"/>
    <SolidColorBrush x:Key="DiffFileBrush" Color="{DynamicResource DiffFile}"/>
    <SolidColorBrush x:Key="EditorSelectionBorderBrush" Color="{DynamicResource EditorSelectionBorder}"/>
    <SolidColorBrush x:Key="EditorCurrentLineBrush" Color="{DynamicResource EditorCurrentLine}"/>
    <SolidColorBrush x:Key="EditorGutterBgBrush" Color="{DynamicResource EditorGutterBg}"/>
    <SolidColorBrush x:Key="EditorScrollbarBgBrush" Color="{DynamicResource EditorScrollbarBg}"/>
    <SolidColorBrush x:Key="EditorScrollbarThumbBrush" Color="{DynamicResource EditorScrollbarThumb}"/>
    <SolidColorBrush x:Key="EditorScrollbarThumbHoverBrush" Color="{DynamicResource EditorScrollbarThumbHover}"/>
    <SolidColorBrush x:Key="OkBrush" Color="{DynamicResource Ok}"/>
    <SolidColorBrush x:Key="WarnBrush" Color="{DynamicResource Warn}"/>
    <SolidColorBrush x:Key="ErrBrush" Color="{DynamicResource Err}"/>
    <SolidColorBrush x:Key="GlassOverlayBrush" Color="{DynamicResource GlassOverlay}"/>
    <SolidColorBrush x:Key="RowAltBrush" Color="{StaticResource RowAltColor}"/>
    <SolidColorBrush x:Key="MenuBgBrush" Color="{DynamicResource MenuBg}"/>
    <SolidColorBrush x:Key="TitleBarBgBrush" Color="{DynamicResource TitleBarBg}"/>
    <SolidColorBrush x:Key="TitleBarFgBrush" Color="{DynamicResource FgLight}"/>
    <SolidColorBrush x:Key="BgInputBrush" Color="#1A1E2A"/>
    <SolidColorBrush x:Key="BgButtonBrush" Color="#333745"/>
    <SolidColorBrush x:Key="BgButtonHoverBrush" Color="#3D4150"/>
    <SolidColorBrush x:Key="BgButtonBorderBrush" Color="#4A4E5C"/>
    <SolidColorBrush x:Key="FgButtonBrush" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="AppTitleBrush" Color="{StaticResource AppTitleColor}"/>
    <SolidColorBrush x:Key="AppSubtitleBrush" Color="{StaticResource AppSubtitleColor}"/>

    <!-- VS Code syntax tokens (resolved by AvalonEdit via resource name) -->
    <SolidColorBrush x:Key="VsKeyword"  Color="#569CD6"/>
    <SolidColorBrush x:Key="VsString"   Color="#CE9178"/>
    <SolidColorBrush x:Key="VsComment"  Color="#6A9955"/>
    <SolidColorBrush x:Key="VsNumber"   Color="#B5CEA8"/>
    <SolidColorBrush x:Key="VsType"     Color="#4EC9B0"/>
    <SolidColorBrush x:Key="VsFunction" Color="#DCDCAA"/>
    <SolidColorBrush x:Key="VsVariable" Color="#9CDCFE"/>
    <SolidColorBrush x:Key="VsOperator" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="VsPreproc"  Color="#C586C0"/>
    <SolidColorBrush x:Key="VsTag"      Color="#569CD6"/>
    <SolidColorBrush x:Key="VsAttr"     Color="#9CDCFE"/>
    <SolidColorBrush x:Key="VsPunct"    Color="#D4D4D4"/>
    <SolidColorBrush x:Key="VsConst"    Color="#569CD6"/>
    <SolidColorBrush x:Key="VsBool"     Color="#569CD6"/>
    <SolidColorBrush x:Key="VsEditorBg"   Color="#1E1E1E"/>
    <SolidColorBrush x:Key="VsEditorFg"   Color="#D4D4D4"/>
    <SolidColorBrush x:Key="VsLineNumber" Color="#858585"/>
    <SolidColorBrush x:Key="VsSelection"  Color="#264F78"/>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{DynamicResource Accent}" Offset="0"/>
        <GradientStop Color="{DynamicResource AccentSecondary}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientVertical" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource Accent}" Offset="0"/>
        <GradientStop Color="{DynamicResource AccentSecondary}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TitleBarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource TitleBarGradientTopColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource TitleBarBg}" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="PanelShadow" Color="#00000040"/>
</ResourceDictionary>
