<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         Close tab button style — used in panel tabs, terminal tabs, etc.
         ════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="CloseTabButtonStyle" TargetType="Button">
        <Setter Property="Content" Value="✕"/>
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="FontSize" Value="8"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         Close panel button style — larger close button for panel headers
         ════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="ClosePanelButtonStyle" TargetType="Button">
        <Setter Property="Content" Value="✕"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         Add tab button style — small "+" button for adding new tabs
         ════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="AddTabButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="ToolTip" Value="{DynamicResource Tab.New}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         Bottom panel header — title bar for tools/terminal bottom panels
         ════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="BottomPanelHeaderStyle" TargetType="Border">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="{DynamicResource BgHeaderBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         Panel tab header — text label used inside tab strip header borders
         ════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="TabHeaderTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         Keyboard hint badge — small label for keyboard shortcuts (F1, Tab, ESC)
         ════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="KeyboardHintBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>
