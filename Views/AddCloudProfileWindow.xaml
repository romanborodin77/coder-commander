<Window x:Class="CoderCommander.Views.AddCloudProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CoderCommander.Models"
        Title="{DynamicResource Cloud.AddProfileTitle}"
        Width="480" Height="420"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPanelBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Width" Value="100"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <!-- Titlebar -->
            <Border DockPanel.Dock="Top" Height="36"
                    Background="{DynamicResource TitleBarBgBrush}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Foreground="{DynamicResource FgLightBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Width="36" Height="36"
                            HorizontalAlignment="Right"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="CloseButton_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{DynamicResource Cloud.ProfileNameLabel}"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ProfileName"
                         Style="{StaticResource FieldInput}"
                         Margin="0,4,0,8"/>

                <!-- Provider -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{DynamicResource Cloud.ProviderLabel}"
                           Style="{StaticResource FieldLabel}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ProviderCombo"
                          Width="200" HorizontalAlignment="Left"
                          Margin="0,4,0,8"
                          SelectionChanged="Provider_Changed">
                    <ComboBoxItem Tag="S3" Content="Amazon S3 / S3-compatible"/>
                    <ComboBoxItem Tag="AzureBlob" Content="Azure Blob Storage"/>
                    <ComboBoxItem Tag="GoogleDrive" Content="Google Drive"/>
                    <ComboBoxItem Tag="YandexDisk" Content="Yandex Disk"/>
                    <ComboBoxItem Tag="NextCloud" Content="NextCloud (WebDAV)"/>
                    <ComboBoxItem Tag="WebDAV" Content="WebDAV (custom)"/>
                </ComboBox>

                <!-- Dynamic fields panel -->
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" x:Name="FieldsPanel" Margin="0,4,0,0"/>

                <!-- Ignore cert -->
                <CheckBox Grid.Row="9" Grid.ColumnSpan="2" x:Name="IgnoreCertCheck"
                          Content="{DynamicResource Cloud.IgnoreCert}"
                          Foreground="{DynamicResource FgDimBrush}"
                          FontSize="11"
                          Margin="0,8,0,0"
                          Visibility="Collapsed"/>

                <!-- Buttons -->
                <StackPanel Grid.Row="10" Grid.ColumnSpan="2"
                            Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Style="{StaticResource DefaultButtonStyle}"
                            Width="90" Height="30" Margin="0,0,8,0"
                            Click="CancelButton_Click">
                        <TextBlock Text="{DynamicResource Cloud.CancelBtn}" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="AddButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="100" Height="30"
                            Click="AddButton_Click">
                        <TextBlock x:Name="AddButtonText" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
