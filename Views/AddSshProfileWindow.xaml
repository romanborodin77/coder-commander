<Window x:Class="CoderCommander.Views.AddSshProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CoderCommander.Models"
        Title="{DynamicResource Ssh.Editor}"
        Width="480" Height="420"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPanelBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Width" Value="120"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style x:Key="FieldPassword" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <!-- Titlebar -->
            <Border DockPanel.Dock="Top" Height="36"
                    Background="{DynamicResource TitleBarBgBrush}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Foreground="{DynamicResource FgLightBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Width="36" Height="36"
                            HorizontalAlignment="Right"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="CloseButton_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{DynamicResource Ssh.ProfileName}"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ProfileName"
                         Style="{StaticResource FieldInput}"
                         Margin="0,4,0,8"/>

                <!-- Host -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{DynamicResource Ssh.Host}"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="Host"
                         Style="{StaticResource FieldInput}"
                         Margin="0,4,0,8"/>

                <!-- User -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{DynamicResource Ssh.User}"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="User"
                         Style="{StaticResource FieldInput}"
                         Margin="0,4,0,8"/>

                <!-- Password -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="{DynamicResource Ssh.Password}"
                           Style="{StaticResource FieldLabel}"/>
                <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="Password"
                             Style="{StaticResource FieldPassword}"
                             Margin="0,4,0,8"/>

                <!-- Port -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="{DynamicResource Ssh.Port}"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="Port"
                         Style="{StaticResource FieldInput}"
                         Text="22"
                         Margin="0,4,0,8"/>

                <!-- Remote Path -->
                <TextBlock Grid.Row="5" Grid.Column="0"
                           Text="{DynamicResource Ssh.RemotePath}"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="RemotePath"
                         Style="{StaticResource FieldInput}"
                         Text="/"
                         Margin="0,4,0,8"/>

                <!-- Identity File -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="{DynamicResource Ssh.IdentityFile}"
                           Style="{StaticResource FieldLabel}"/>
                <Grid Grid.Row="6" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="IdentityFile"
                             Style="{StaticResource FieldInput}"
                             Margin="0,4,4,8"
                             IsReadOnly="True"/>
                    <Button Grid.Column="1"
                            Width="28" Height="28"
                            Margin="0,4,0,8"
                            Click="BrowseIdentityFile_Click"
                            ToolTip="{DynamicResource Ssh.Tip.KeyFile}"
                            Style="{StaticResource ToolbarButtonStyle}">
                        <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Row="9" Grid.ColumnSpan="2"
                            Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Style="{StaticResource DefaultButtonStyle}"
                            Width="90" Height="30" Margin="0,0,8,0"
                            Click="CancelButton_Click">
                        <TextBlock x:Name="CancelButtonText" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="AddButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="100" Height="30"
                            Click="AddButton_Click">
                        <TextBlock x:Name="AddButtonText" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
