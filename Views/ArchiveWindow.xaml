<Window x:Class="CoderCommander.Views.ArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Title="{DynamicResource Archive.Title}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Width="800" Height="600"
        MinWidth="500" MinHeight="400"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="6" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="ArchiveEntryTemplate">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}" FontSize="11"
                           Foreground="{DynamicResource FgLightBrush}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           ToolTip="{Binding Key}" Margin="0,0,12,0" MinWidth="160"/>
                <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                           Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBlock Text="{Binding CompressedDisplay}" FontSize="10"
                           Foreground="{DynamicResource FgMutedBrush}" VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBlock Text="{Binding LastModified, StringFormat='yyyy-MM-dd HH:mm'}" FontSize="10"
                           Foreground="{DynamicResource FgMutedBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom TitleBar -->
        <Border Grid.Row="0" Height="36"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="&#xE7B8;"
                           Foreground="{DynamicResource FgLightBrush}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Margin="12,0,4,0"/>
                <TextBlock Grid.Column="1"
                           Text="{DynamicResource Archive.Title}"
                           Foreground="{DynamicResource FgLightBrush}"
                           VerticalAlignment="Center"
                           FontSize="13"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                     <Button Content="&#xE921;" ToolTip="{DynamicResource Archive.Tip.Minimize}" Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"/>
                     <Button x:Name="MaximizeButton" Content="&#xE922;" ToolTip="{DynamicResource Archive.Tip.Maximize}"
                            Click="MaximizeButton_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                     <Button Content="&#xE8BB;" ToolTip="{DynamicResource Archive.Tip.Close}" Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Содержимое — два режима -->
        <TabControl Grid.Row="1" Margin="8"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    Background="{DynamicResource BgDarkBrush}"
                    BorderThickness="0">

            <!-- ═══════════════════════════════════════ -->
            <!-- Вкладка «Создать архив» / Create archive -->
            <!-- ═══════════════════════════════════════ -->
            <TabItem Header="{DynamicResource Archive.TabCreate}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Путь назначения / Destination path -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Archive.OutputPath}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource BgInputBrush}"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1" Padding="4,2"/>
                        <Button Grid.Column="2" Content="⋯" Width="28"
                                Margin="4,0,0,0"
                                Command="{Binding BrowseOutputPathCommand}"
                                ToolTip="{DynamicResource Archive.BrowseOutput}"/>
                    </Grid>

                    <!-- Формат + Сжатие + Пароль / Format + Compression + Password -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Archive.Format}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1"
                                  SelectedIndex="{Binding SelectedFormatIndex}"
                                  Background="{DynamicResource BgInputBrush}"
                                  Foreground="{DynamicResource FgLightBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="{DynamicResource Archive.Format.Zip}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.Format.SevenZip}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.Format.Tar}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.Format.TarGz}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.Format.TarBz2}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.Format.GZip}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.Format.BZip2}"/>
                        </ComboBox>
                        <TextBlock Grid.Column="3" Text="{DynamicResource Archive.Compression}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="4"
                                  SelectedIndex="{Binding SelectedCompressionIndex}"
                                  Background="{DynamicResource BgInputBrush}"
                                  Foreground="{DynamicResource FgLightBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="{DynamicResource Archive.CompNone}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.CompFast}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.CompOptimal}"/>
                            <ComboBoxItem Content="{DynamicResource Archive.CompBest}"/>
                        </ComboBox>
                        <TextBlock Grid.Column="6" Text="{DynamicResource Archive.Password}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <PasswordBox Grid.Column="7"
                                  x:Name="ArchivePasswordBox"
                                  Background="{DynamicResource BgInputBrush}"
                                  Foreground="{DynamicResource FgLightBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1" Padding="4,2"
                                 />
                    </Grid>

                    <!-- Список файлов / File list -->
                    <Grid Grid.Row="2" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0"
                                     Text="{Binding CreateFileCountDisplay}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="{DynamicResource Archive.ClearFiles}"
                                Command="{Binding ClearCreateFilesCommand}"
                                Padding="8,2" Margin="4,0,0,0" Style="{DynamicResource DefaultButtonStyle}"/>
                    </Grid>

                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding CreateFiles}"
                             Background="{DynamicResource BgDarkBrush}"
                             Foreground="{DynamicResource FgLightBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             SelectionMode="Extended"/>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════ -->
            <!-- Вкладка «Извлечь архив» / Extract archive -->
            <!-- ═══════════════════════════════════════ -->
            <TabItem Header="{DynamicResource Archive.TabExtract}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Архив / Archive path -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Archive.ArchivePath}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ExtractArchivePath, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource BgInputBrush}"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1" Padding="4,2"
                                 IsReadOnly="True"/>
                    </Grid>

                    <!-- Путь назначения + перезапись / Destination + overwrite -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Archive.ExtractTo}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ExtractOutputPath, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource BgInputBrush}"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1" Padding="4,2"/>
                        <Button Grid.Column="2" Content="⋯" Width="28"
                                Margin="4,0,0,0"
                                Command="{Binding BrowseExtractOutputCommand}"
                                ToolTip="{DynamicResource Archive.BrowseExtractTo}"/>
                        <TextBlock Grid.Column="4" Text="{DynamicResource Archive.Password}"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <PasswordBox Grid.Column="5"
                                  x:Name="ExtractPasswordBox"
                                  Background="{DynamicResource BgInputBrush}"
                                  Foreground="{DynamicResource FgLightBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1" Padding="4,2"
                                 />
                    </Grid>

                    <!-- Содержимое архива / Archive contents -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0"
                                         Text="{Binding ExtractEntryCountDisplay}"
                                       Foreground="{DynamicResource FgLightBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="{DynamicResource Archive.SelectAll}"
                                    Command="{Binding SelectAllEntriesCommand}"
                                    Padding="8,2" Margin="4,0,4,0" Style="{DynamicResource DefaultButtonStyle}"/>
                            <Button Grid.Column="2" Content="{DynamicResource Archive.SelectNone}"
                                    Command="{Binding SelectNoneEntriesCommand}"
                                    Padding="8,2" Style="{DynamicResource DefaultButtonStyle}"/>
                        </Grid>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding ExtractEntries}"
                                 Background="{DynamicResource BgDarkBrush}"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 SelectionMode="Extended"
                                 ItemTemplate="{DynamicResource ArchiveEntryTemplate}"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Row 2: Кнопки + прогресс / Buttons + Progress -->
        <Grid Grid.Row="2" Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Прогресс-бар / Progress bar -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource FgMutedBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,4"/>
                <ProgressBar Grid.Row="1"
                              Value="{Binding ProgressValue, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Height="4"
                             Background="{DynamicResource BgHeaderBrush}"
                             Foreground="{DynamicResource AccentBrush}"/>
            </Grid>

            <!-- Кнопки / Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{DynamicResource Archive.Create}"
                        Command="{Binding CreateArchiveCommand}"
                        Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVis}}"
                        Padding="16,6" Margin="4,0"
                        FontWeight="SemiBold" Style="{DynamicResource AccentButtonStyle}"/>
                <Button Content="{DynamicResource Archive.Extract}"
                        Command="{Binding ExtractArchiveCommand}"
                        Visibility="{Binding IsExtractMode, Converter={StaticResource BoolToVis}}"
                        Padding="16,6" Margin="4,0"
                        FontWeight="SemiBold" Style="{DynamicResource AccentButtonStyle}"/>
                <Button Content="{DynamicResource Archive.Cancel}"
                        Command="{Binding CancelCommand}"
                        Padding="16,6" Margin="4,0" Style="{DynamicResource DefaultButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Row 3: Status bar -->
        <Border Grid.Row="3" Height="26"
                Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource FgMutedBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
