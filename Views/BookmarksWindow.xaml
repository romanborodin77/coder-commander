<Window x:Class="CoderCommander.Views.BookmarksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CoderCommander.ViewModels"
        Title="{DynamicResource Bookmark.Manage}"
        Width="520" Height="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="{DynamicResource BgDarkBrush}">

    <Window.DataContext>
        <vm:BookmarksViewModel/>
    </Window.DataContext>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <!-- ═══ CUSTOM TITLE BAR ═══ -->
        <Border x:Name="TitleBar"
                Panel.ZIndex="3000"
                VerticalAlignment="Top"
                Height="36"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Title -->
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource Bookmark.Manage}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgLightBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>
                <!-- Close -->
                <Button Grid.Column="1"
                        Style="{StaticResource TitleBarCloseButtonStyle}"
                        Click="CloseWindow"
                        ToolTip="{DynamicResource Editor.Tip.Close}">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <DockPanel Margin="0,36,0,0">
            <!-- ═══ TOOLBAR ═══ -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource BgHeaderBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarAccentStyle}"
                            Command="{Binding AddBookmarkCommand}"
                            ToolTip="{DynamicResource Bookmark.Add}"
                            Width="34" Height="30">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                    <Border Style="{StaticResource ToolbarSepStyle}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding RenameBookmarkCommand}"
                            ToolTip="{DynamicResource Bookmark.Rename}"
                            Width="34" Height="30">
                        <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding RemoveBookmarkCommand}"
                            ToolTip="{DynamicResource Bookmark.Remove}"
                            Width="34" Height="30">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource ErrBrush}"/>
                    </Button>
                    <Border Style="{StaticResource ToolbarSepStyle}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding MoveUpCommand}"
                            ToolTip="{DynamicResource Bookmark.Tip.Up}"
                            Width="34" Height="30">
                        <TextBlock Text="&#xE73A;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding MoveDownCommand}"
                            ToolTip="{DynamicResource Bookmark.Tip.Down}"
                            Width="34" Height="30">
                        <TextBlock Text="&#xE73B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Border Style="{StaticResource ToolbarSepStyle}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ExportCommand}"
                            ToolTip="{DynamicResource Bookmark.Export}"
                            Width="34" Height="30">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ImportCommand}"
                            ToolTip="{DynamicResource Bookmark.Import}"
                            Width="34" Height="30">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ═══ BOOKMARKS LIST ═══ -->
            <Border DockPanel.Dock="Bottom"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding BookmarksCountDisplay}"
                               FontSize="11"
                               Foreground="{DynamicResource FgMutedBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ListBox x:Name="BookmarksList"
                     ItemsSource="{Binding Bookmarks}"
                     SelectedItem="{Binding SelectedBookmark}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="0"
                     Padding="4"
                     MouseDoubleClick="BookmarksList_DblClick"
                     KeyDown="BookmarksList_KeyDown">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Margin" Value="2,2"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Icon -->
                            <Border Grid.Column="0"
                                    Width="28" Height="28"
                                    CornerRadius="6"
                                    Background="{DynamicResource AccentDimBrush}"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <!-- Name + Path -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource FgLightBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Path}"
                                           FontSize="11"
                                           Foreground="{DynamicResource FgDimBrush}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
