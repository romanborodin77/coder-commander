<UserControl x:Class="CoderCommander.Views.CloudStoragePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CoderCommander.Converters">
    <UserControl.Resources>
        <Style x:Key="CloudBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <DockPanel>
            <!-- ===== Панель подключения ===== -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource BgHeaderBrush}" Padding="8,4">
                <DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name"
                                  Width="200"
                                  ToolTip="{DynamicResource Cloud.SelectProfile}"/>
                        <Button Command="{Binding ConnectCommand}" Margin="4,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource CloudBtn}">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8CD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.Connect}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8CD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource Cloud.Reconnect}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding DisconnectCommand}" Margin="4,0,0,0"
                                Style="{StaticResource CloudBtn}" ToolTip="{DynamicResource Cloud.DisconnectTip}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Cloud.DisconnectBtn}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Ellipse Width="10" Height="10" Margin="6,0,0,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource FgDimBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource OkBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <Separator Style="{DynamicResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="6,2"/>

                        <Button Command="{Binding RefreshCommand}"
                                Margin="4,0,0,0" Style="{StaticResource CloudBtn}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x27F3; " VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Cloud.Refresh}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DownloadToCommand}"
                                Margin="4,0,0,0" Style="{StaticResource CloudBtn}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x2B07; " VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Cloud.Download}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding UploadFromCommand}"
                                Margin="4,0,0,0" Style="{StaticResource CloudBtn}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x2B06; " VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Cloud.Upload}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding MakeDirCommand}"
                                Margin="4,0,0,0" Style="{StaticResource CloudBtn}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xFF0B; " VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Cloud.NewFolder}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== Строка пути ===== -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource BgPanelBrush}" Padding="8,5">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding GoUpCommand}"
                            Margin="6,0,0,0" Style="{StaticResource CloudBtn}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#x2191; " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.Up}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{DynamicResource Cloud.Path}"
                               Foreground="{DynamicResource FgDimBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ===== Конфигурация Google Drive (OAuth2) ===== -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource BgHeaderBrush}"
                    Padding="8,6"
                    Visibility="{Binding IsGDriveConfigVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Cloud.GDrive.OAuthTitle}"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                    Text="{DynamicResource Cloud.GDrive.ClientId}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="11"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding GDriveClientId, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="6,2"
                                 VerticalContentAlignment="Center"
                                 FontSize="11"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                    Text="{DynamicResource Cloud.GDrive.ClientSecret}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="11"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding GDriveClientSecret, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="6,2"
                                 VerticalContentAlignment="Center"
                                 FontSize="11"/>

                        <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                                Command="{Binding SaveGDriveCredentialsCommand}"
                                Style="{StaticResource CloudBtn}"
                                Content="{DynamicResource Cloud.GDrive.SaveCredentials}"
                                Margin="4,2,0,2"
                                VerticalAlignment="Stretch"
                                ToolTip="{DynamicResource Cloud.GDrive.SaveCredentialsTip}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Command="{Binding AuthorizeGoogleDriveCommand}"
                                Style="{StaticResource CloudBtn}"
                                IsEnabled="{Binding IsGDriveAuthorizing, Converter={StaticResource InverseBool}}"
                                Padding="12,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Cloud.GDrive.AuthorizeInBrowser}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding GDriveStatus}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource FgDimBrush}"/>
                    </StackPanel>
                    <TextBlock Margin="0,2,0,0" FontSize="10"
                               Foreground="{DynamicResource FgDimBrush}">
                        <Run Text="{DynamicResource Cloud.GDrive.GetCredentialsAt}"/>
                        <Hyperlink NavigateUri="https://console.cloud.google.com/apis/credentials"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="{DynamicResource Cloud.GDrive.GoogleCloudConsole}"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ===== Список файлов ===== -->
            <ListBox ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     Background="{DynamicResource BgPanelBrush}"
                     BorderThickness="0"
                     MouseDoubleClick="Item_Dbl"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       Text="{Binding IsDirectory, Converter={StaticResource BoolToIcon}}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{Binding IsDirectory, Converter={StaticResource DirColor}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Size, Converter={StaticResource FileSize}}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       TextAlignment="Right"
                                       Margin="0,0,8,0"/>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding LastWriteTimeUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       FontSize="11"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.OpenItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.OpenCtx}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource Cloud.DownloadCtx}"
                                              Command="{Binding PlacementTarget.Tag.DownloadToCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Cloud.RenameCtx}"
                                              Command="{Binding PlacementTarget.Tag.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}"/>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.DeleteCtx}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Cloud.MakeDirCtx}"
                                              Command="{Binding PlacementTarget.Tag.MakeDirCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- ===== Нижняя панель статуса ===== -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource BgHeaderBrush}"
                    Padding="8,4">
                <DockPanel>
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource FgDimBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource OkBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Status}"
                               Foreground="{DynamicResource FgLightBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- ===== Оверлей загрузки ===== -->
        <Border Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource BgHeaderBrush}"
                    CornerRadius="8" Padding="24,16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Cloud.LoadingOverlay}"
                               Foreground="{DynamicResource FgLightBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
