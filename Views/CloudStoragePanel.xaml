<UserControl x:Class="CoderCommander.Views.CloudStoragePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="CloudToolBtn" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="CloudToolBtnSmall" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ═══ 1. СТРОКА СТАТУСА ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgHeaderBrush}"
                Padding="8,3">
            <DockPanel>
                <Ellipse DockPanel.Dock="Left" Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource FgDimBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource OkBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding Status}"
                           Foreground="{DynamicResource FgLightBrush}"
                           FontSize="10" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- ═══ 2. ВЕРХНЯЯ ПАНЕЛЬ: УПРАВЛЕНИЕ ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE944;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Cloud.Profiles}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgLightBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding AddProfileCommand}"
                            Style="{StaticResource CloudToolBtn}"
                            ToolTip="{DynamicResource Cloud.AddProfile}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.AddBtn}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditProfileCommand}"
                            Style="{StaticResource CloudToolBtn}"
                            ToolTip="{DynamicResource Cloud.EditProfile}"
                            IsEnabled="{Binding SelectedProfile, Converter={StaticResource NullToFalse}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.EditBtn}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteProfileCommand}"
                            Style="{StaticResource CloudToolBtn}"
                            ToolTip="{DynamicResource Cloud.DeleteProfile}"
                            IsEnabled="{Binding SelectedProfile, Converter={StaticResource NullToFalse}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.DeleteBtn}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Style="{DynamicResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>

                    <Button Command="{Binding ConnectSelectedProfileCommand}"
                            Style="{StaticResource CloudToolBtn}"
                            IsEnabled="{Binding SelectedProfile, Converter={StaticResource NullToFalse}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource FgDimBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedProfileConnected}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource OkBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="&#xE8CD;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.ConnectBtn}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DisconnectSelectedProfileCommand}"
                            Style="{StaticResource CloudToolBtn}"
                            IsEnabled="{Binding IsSelectedProfileConnected}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.DisconnectBtnShort}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ 3. СПИСОК ПРОФИЛЕЙ ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4"
                MaxHeight="130">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource Cloud.ProfilesSection}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgDimBrush}"
                           Margin="4,0,0,4"/>
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="2,1" ToolTip="{Binding Name}">
                                <Ellipse DockPanel.Dock="Left" Width="8" Height="8"
                                         Margin="0,0,8,0" VerticalAlignment="Center"
                                         Fill="{DynamicResource FgDimBrush}"/>
                                <TextBlock DockPanel.Dock="Left"
                                           FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding Provider, Converter={StaticResource CloudProviderToIcon}}"/>
                                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="{DynamicResource FgLightBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Provider}" FontSize="10"
                                               Foreground="{DynamicResource FgDimBrush}"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ 4. GOOGLE DRIVE КОНФИГ ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgHeaderBrush}"
                Padding="8,6"
                Visibility="{Binding IsGDriveConfigVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{DynamicResource Cloud.GDrive.OAuthTitle}"
                           FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="85"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{DynamicResource Cloud.GDrive.ClientId}"
                               VerticalAlignment="Center" Foreground="{DynamicResource FgDimBrush}" FontSize="10"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding GDriveClientId, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="10" Margin="4,1" VerticalContentAlignment="Center"/>
                    <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                            Command="{Binding SaveGDriveCredentialsCommand}"
                            Style="{StaticResource CloudToolBtnSmall}"
                            ToolTip="{DynamicResource Cloud.GDrive.SaveCredentialsTip}"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.GDrive.SaveBtn}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{DynamicResource Cloud.GDrive.ClientSecret}"
                               VerticalAlignment="Center" Foreground="{DynamicResource FgDimBrush}" FontSize="10"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding GDriveClientSecret, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" FontSize="10" Margin="4,1" VerticalContentAlignment="Center"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Command="{Binding AuthorizeGoogleDriveCommand}"
                            Style="{StaticResource CloudToolBtnSmall}"
                            IsEnabled="{Binding IsGDriveAuthorizing, Converter={StaticResource InverseBool}}"
                            Padding="10,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cloud.GDrive.AuthBrowserBtn}" VerticalAlignment="Center" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding GDriveStatus}" VerticalAlignment="Center" Margin="8,0,0,0"
                               FontSize="10" Foreground="{DynamicResource FgDimBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ 5. СТРОКА ПУТИ ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}"
                        Style="{StaticResource CloudToolBtnSmall}">
                    <TextBlock Text="&#x27F3;" VerticalAlignment="Center"/>
                </Button>
                <Button DockPanel.Dock="Right" Command="{Binding GoUpCommand}"
                        Style="{StaticResource CloudToolBtnSmall}">
                    <TextBlock Text="&#x2191;" VerticalAlignment="Center"/>
                </Button>
                <TextBlock DockPanel.Dock="Left"
                           Text="{DynamicResource Cloud.PathLabel}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="11"
                         VerticalContentAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ═══ 6. ФАЙЛОВЫЙ БРАУЗЕР ═══ -->
        <Grid>
            <!-- Заглушка -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisInv}}">
                <TextBlock Text="&#xE944;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="{DynamicResource FgDimBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource Cloud.NotConnectedHint}"
                           Foreground="{DynamicResource FgDimBrush}"
                           FontSize="13" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Cloud.NotConnectedHint2}"
                           Foreground="{DynamicResource FgDimBrush}"
                           FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Файловый список -->
            <ListBox ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"
                     MouseDoubleClick="Item_Dbl"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center"
                                       Text="{Binding IsDirectory, Converter={StaticResource BoolToIcon}}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{Binding IsDirectory, Converter={StaticResource DirColor}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Size, Converter={StaticResource FileSize}}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       FontFamily="Consolas" FontSize="10"
                                       TextAlignment="Right" Margin="0,0,8,0"/>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding LastWriteTimeUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FgDimBrush}" FontSize="10"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.OpenItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.OpenCtx}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.DownloadToCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x2B07;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.DownloadCtx}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.RenameCtx}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.DeleteCtx}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.MakeDirCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xFF0B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Cloud.MakeDirCtx}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Оверлей загрузки -->
            <Border Background="{DynamicResource OverlayBrush}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <Border Background="{DynamicResource BgHeaderBrush}"
                        CornerRadius="6" Padding="20,12"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Cloud.LoadingOverlay}"
                                   Foreground="{DynamicResource FgLightBrush}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
