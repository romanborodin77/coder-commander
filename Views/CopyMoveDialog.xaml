<Window x:Class="CoderCommander.Views.CopyMoveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CoderCommander.Converters"
        Title="{Binding Title}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Width="580" Height="520"
        MinWidth="480" MinHeight="400"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <conv:EnumLocalizedConverter x:Key="EnumLocalizedConverter"/>
        <conv:EmptyToCollapsedConverter x:Key="EmptyToCollapsedConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom TitleBar -->
        <Border Grid.Row="0" Height="36"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="&#xE8C8;"
                           FontFamily="Segoe MDL2 Assets" FontSize="15"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,6,0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           Foreground="{DynamicResource FgLightBrush}"
                           VerticalAlignment="Center"
                           FontSize="13"/>
                <Button Grid.Column="2" Content="&#xE8BB;"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Row 1: Content -->
        <Grid Grid.Row="1" Margin="24,16,24,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Source path (readonly) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource CopyMove.Source}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding SourcePath, Mode=OneWay}"
                           Foreground="{DynamicResource FgLightBrush}" FontSize="12"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                           ToolTip="{Binding SourcePath}"/>
            </Grid>

            <!-- Destination path + Browse -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource CopyMove.Destination}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="DestinationBox" Grid.Column="1"
                         Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" VerticalContentAlignment="Center" Padding="6,4"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource FgLightBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>
                <Button Grid.Column="2" Content="{DynamicResource CopyMove.Browse}"
                        Command="{Binding BrowseDestinationCommand}" Margin="8,0,0,0"
                        Padding="10,4" FontSize="12"
                        Style="{DynamicResource DefaultButtonStyle}"/>
            </Grid>

            <!-- Self-copy warning -->
            <TextBlock Grid.Row="4" Text="{Binding SelfCopyWarning}" FontSize="12"
                        Foreground="{DynamicResource WarnBrush}" FontWeight="SemiBold"
                       Visibility="{Binding SelfCopyWarning, Converter={StaticResource EmptyToCollapsedConverter}}"/>

            <!-- File count + total size -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="12" Foreground="{DynamicResource FgDimBrush}">
                    <Run Text="{DynamicResource CopyMove.FileCount}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding FileCount, Mode=OneWay}" Foreground="{DynamicResource FgLightBrush}"/>
                </TextBlock>
                <TextBlock Grid.Column="2" FontSize="12" Foreground="{DynamicResource FgDimBrush}">
                    <Run Text="{DynamicResource CopyMove.TotalSize}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding TotalSizeText, Mode=OneWay}" Foreground="{DynamicResource FgLightBrush}"/>
                </TextBlock>
            </Grid>

            <!-- Source items list (scrollable) -->
            <Border Grid.Row="8"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SourceItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{DynamicResource FgDimBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="{DynamicResource FgLightBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Options -->
            <StackPanel Grid.Row="10">
                <!-- Политика перезаписи / Overwrite policy -->
                <DockPanel Margin="0,4">
                    <TextBlock DockPanel.Dock="Left" Text="{DynamicResource CopyMove.OverwritePolicy}"
                               Foreground="{DynamicResource FgLightBrush}" FontSize="12"
                               VerticalAlignment="Center" Width="180"/>
                    <ComboBox ItemsSource="{Binding SelectedOverwritePolicy, Converter={StaticResource EnumLocalizedConverter}, ConverterParameter=OverwritePolicy}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"
                              SelectedValue="{Binding SelectedOverwritePolicy}"
                              FontSize="12" VerticalContentAlignment="Center"
                              Background="{DynamicResource SurfaceBrush}"
                              Foreground="{DynamicResource FgLightBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"/>
                </DockPanel>

                <CheckBox Content="{DynamicResource CopyMove.CopyAttributes}"
                          IsChecked="{Binding CopyAttributes}" Margin="0,6"
                          Foreground="{DynamicResource FgLightBrush}" FontSize="12"/>
                <CheckBox Content="{DynamicResource CopyMove.CopyTimestamps}"
                          IsChecked="{Binding CopyTimestamps}" Margin="0,4"
                          Foreground="{DynamicResource FgLightBrush}" FontSize="12"/>
                <CheckBox Content="{DynamicResource CopyMove.CopyNtfsPermissions}"
                          IsChecked="{Binding CopyNtfsPermissions}" Margin="0,4"
                          Foreground="{DynamicResource FgLightBrush}" FontSize="12"/>
                <CheckBox Content="{DynamicResource CopyMove.AddToQueue}"
                          IsChecked="{Binding AddToQueue}" Margin="0,8,0,0"
                          Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource CopyMove.Cancel}"
                        Command="{Binding CancelCommand}" Margin="0,0,8,0"
                        Padding="16,7" FontSize="13"
                        Style="{DynamicResource DefaultButtonStyle}"/>
                <Button Content="{DynamicResource CopyMove.OK}"
                        Command="{Binding OKCommand}"
                        Padding="16,7" FontSize="13" FontWeight="SemiBold"
                        Style="{DynamicResource AccentButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
