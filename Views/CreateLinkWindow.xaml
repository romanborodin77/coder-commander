<Window x:Class="CoderCommander.Views.CreateLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Width="560" Height="Auto"
        MinWidth="460" MinHeight="200"
        SizeToContent="Height"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources/>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Title bar ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Border Width="18" Height="18" Background="{DynamicResource AccentDimBrush}" CornerRadius="5" Margin="0,0,9,0">
                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgLightBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid Grid.Column="1" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Grid.Column="2" Style="{StaticResource CloseButtonStyle}"
                        Command="{Binding CancelCommand}">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Content ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="14">
            <StackPanel>
                <!-- Информация о типе ссылки / Link type info -->
                <Border Style="{StaticResource LinkGroupStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Link.Type}" Style="{StaticResource LinkLabelStyle}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TypeName}" Foreground="{DynamicResource FgLightBrush}"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Путь источника / Source path -->
                <Border Style="{StaticResource LinkGroupStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Link.Target}" Style="{StaticResource LinkGroupTitleStyle}"/>
                        <TextBox Text="{Binding TargetPath, Mode=OneWay}" IsReadOnly="True"
                                 VerticalContentAlignment="Center" Padding="8,6"
                                 Foreground="{DynamicResource FgMutedBrush}" FontSize="11"
                                 TextWrapping="Wrap" Background="Transparent"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <!-- Режим одного файла / Single file mode -->
                <Border Style="{StaticResource LinkGroupStyle}" Visibility="{Binding IsMultiMode, Converter={StaticResource BoolToVisInv}}">
                    <StackPanel>
                        <!-- Имя ссылки / Link name -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Link.Name}" Style="{StaticResource LinkLabelStyle}"/>
                            <TextBox x:Name="LinkNameBox" Grid.Column="1" Text="{Binding LinkName, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center" Padding="8,4"/>
                        </Grid>
                        <!-- Путь ссылки / Link path -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Link.Path}" Style="{StaticResource LinkLabelStyle}"/>
                            <TextBox Grid.Column="1" Text="{Binding LinkPath, Mode=OneWay}" IsReadOnly="True"
                                     VerticalContentAlignment="Center" Padding="8,4"
                                     Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Режим нескольких файлов / Multiple files mode -->
                <Border Style="{StaticResource LinkGroupStyle}" Visibility="{Binding IsMultiMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Link.MultipleFiles}" Style="{StaticResource LinkGroupTitleStyle}"/>
                        <ItemsControl ItemsSource="{Binding LinkEntries}" MaxHeight="200">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SourcePath}" Foreground="{DynamicResource FgMutedBrush}"
                                                   FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding LinkName, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center" Padding="6,3" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Статус / Status -->
                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource FgMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Footer: кнопки ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Style="{StaticResource AccentLinkButtonStyle}" Command="{Binding CreateCommand}" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Link.Create}"/>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource AccentLinkButtonStyle}" Command="{Binding CancelCommand}"
                        Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource FgLightBrush}">
                    <TextBlock Text="{DynamicResource Link.Cancel}"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
