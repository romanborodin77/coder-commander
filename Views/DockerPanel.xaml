<UserControl x:Class="CoderCommander.Views.DockerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CoderCommander.Converters">
    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgHeaderBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style x:Key="ToolbarBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="22"/>
            <Setter Property="MinHeight" Value="20"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар -->
        <Border Grid.Row="0" Background="{DynamicResource BgHeaderBrush}" Padding="8,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="⟳" ToolTip="{DynamicResource Docker.Tip.Refresh}"
                            Command="{Binding RefreshCommand}" Style="{DynamicResource ToolbarBtn}"/>
                    <Separator Margin="4,2"/>
                    <Button Content="▶" ToolTip="{DynamicResource Docker.Tip.Start}"
                            Command="{Binding StartCommand}" Style="{DynamicResource ToolbarBtn}"/>
                    <Button Content="■" ToolTip="{DynamicResource Docker.Tip.Stop}"
                            Command="{Binding StopCommand}" Margin="4,0,0,0" Style="{DynamicResource ToolbarBtn}"/>
                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" ToolTip="{DynamicResource Docker.Tip.Remove}"
                            Command="{Binding RemoveCommand}" Margin="4,0,0,0" Style="{DynamicResource ToolbarBtn}"/>
                    <Separator Margin="4,2"/>
                    <Button ToolTip="{DynamicResource Docker.Tip.Logs}"
                            Command="{Binding ShowLogsCommand}" Style="{DynamicResource ToolbarBtn}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Docker.Logs}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource FgDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Основная зона: 2 колонки -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="120"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="3*" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- ===== ЛЕВАЯ ПАНЕЛЬ: Контейнеры ===== -->
            <DockPanel Grid.Column="0" Background="{DynamicResource BgPanelBrush}">
                <Border Style="{DynamicResource SectionHeader}">
                    <TextBlock Text="{DynamicResource Docker.Containers}" FontWeight="SemiBold" FontSize="13"/>
                </Border>

                <!-- Пустое состояние -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Containers.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                        <TextBlock Text="⊘" FontSize="40" Foreground="{DynamicResource FgDimBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Docker.NoContainers}" Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Docker.RunHint}"
                                   Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Список контейнеров -->
                <ListBox ItemsSource="{Binding Containers}" SelectedItem="{Binding SelectedContainer}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,4" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.RowSpan="3"
                                               Grid.Column="0"
                                               Text="●" FontSize="14"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="running">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffAddBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="exited">
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="paused">
                                                        <Setter Property="Foreground" Value="{DynamicResource WarnBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="created">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffMetaBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="restarting">
                                                        <Setter Property="Foreground" Value="{DynamicResource WarnBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,0,0,0"/>

                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Image}"
                                               Foreground="{DynamicResource FgDimBrush}"
                                               FontSize="11"
                                               Margin="4,1,0,0"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Status}"
                                               Foreground="{DynamicResource FgDimBrush}"
                                               FontSize="10"
                                               Margin="4,1,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Opacity="0.8"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" Width="6"
                          Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"/>

            <!-- ===== ПРАВАЯ ПАНЕЛЬ: Exec + Логи + Образы ===== -->
            <DockPanel Grid.Column="2" Background="{DynamicResource BgPanelBrush}">
                <!-- Exec команда -->
                <Border Style="{DynamicResource SectionHeader}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="▶ Exec"
                                ToolTip="{DynamicResource Docker.Tip.Exec}"
                                Command="{Binding ExecInContainerCommand}"
                                Style="{DynamicResource ToolbarBtn}"
                                FontWeight="SemiBold"
                                Padding="10,4"/>
                <TextBox Text="{Binding ExecCommand, UpdateSourceTrigger=PropertyChanged}"
                                  Background="{DynamicResource SurfaceDeepBrush}"
                                  Foreground="{DynamicResource FgLightBrush}"
                                 ToolTip="{DynamicResource Docker.Tip.ExecCmd}"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="6,3"
                                 VerticalContentAlignment="Center"
                                 BorderThickness="0"/>
                    </DockPanel>
                </Border>

                <!-- Логи контейнера -->
                <Border Style="{DynamicResource SectionHeader}">
                    <TextBlock Text="{DynamicResource Docker.Logs}" FontWeight="SemiBold" FontSize="12"/>
                </Border>

                <TextBox Text="{Binding Logs, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="11"
                         TextWrapping="Wrap"
                         Background="{DynamicResource SurfaceDeepBrush}"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Padding="6,4"/>

                <!-- Образы -->
                <Border Style="{DynamicResource SectionHeader}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Docker.Images}" FontWeight="SemiBold" FontSize="12"/>
                        <Button Grid.Column="1" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                ToolTip="{DynamicResource Docker.Tip.RemoveImage}"
                                Command="{Binding RemoveImageCommand}"
                                Style="{DynamicResource IconBtn}"/>
                    </Grid>
                </Border>

                <ListBox ItemsSource="{Binding Images}" SelectedItem="{Binding SelectedImage}"
                         Background="Transparent" BorderThickness="0"
                         MaxHeight="140">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="4,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="11" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Repository}"/>
                                        <Run Text=":" Foreground="{DynamicResource FgDimBrush}"/>
                                        <Run Text="{Binding Tag}" Foreground="{DynamicResource FgDimBrush}"/>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               Text="{Binding Size}"
                                               Foreground="{DynamicResource FgDimBrush}"
                                               FontSize="10"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
