<Window x:Class="CoderCommander.Views.DuplicatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vmLocal="clr-namespace:CoderCommander.Views"
        Title="{DynamicResource Dup.Title}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Width="1000" Height="680"
        MinWidth="720" MinHeight="480"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources/>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Заголовок / Title bar -->
        <Border Grid.Row="0" Height="36"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,4,0">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Dup.Title}" Foreground="{DynamicResource FgLightBrush}"
                               FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="&#xE921;" ToolTip="{DynamicResource Editor.Tip.Minimize}" Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"/>
                    <Button x:Name="MaximizeButton" Content="&#xE922;" ToolTip="{DynamicResource Editor.Tip.Maximize}"
                            Click="MaximizeButton_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                    <Button Content="&#xE8BB;" ToolTip="{DynamicResource Editor.Tip.Close}" Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Параметры поиска / Search options -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Папка + обзор / Folder + browse -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Dup.Folder}"
                               Foreground="{DynamicResource FgMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Text="{Binding RootFolder, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource BgDarkBrush}" Foreground="{DynamicResource FgLightBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6,4" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="{DynamicResource Dup.Browse}" Click="Browse_Click"
                            Margin="8,0,0,0" Padding="12,4" Style="{DynamicResource DefaultButtonStyle}"/>
                </Grid>

                <!-- Критерий + подпапки + кнопки / Criterion + subfolders + buttons -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Dup.Criterion}"
                               Foreground="{DynamicResource FgMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Criteria}"
                              DisplayMemberPath="Display"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding Criterion}"
                              Background="{DynamicResource BgDarkBrush}" Foreground="{DynamicResource FgLightBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"/>
                    <CheckBox Grid.Column="2" Content="{DynamicResource Dup.IncludeSubfolders}"
                              IsChecked="{Binding IncludeSubfolders}"
                              Foreground="{DynamicResource FgLightBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Row 2: Результаты / Results -->
        <TreeView Grid.Row="2" ItemsSource="{Binding Groups}"
                  Background="{DynamicResource BgDarkBrush}" BorderThickness="0"
                  Padding="6">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type vmLocal:DuplicateGroup}" ItemsSource="{Binding Items}">
                    <StackPanel Orientation="Horizontal" Margin="2,2">
                        <TextBlock Style="{StaticResource GroupHeaderStyle}" Text="{Binding Key}"/>
                        <TextBlock Foreground="{DynamicResource FgMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0">
                            <Run Text="{Binding Size, Converter={StaticResource FileSize}}"/>
                            <Run Text="  •  "/>
                            <Run Text="{Binding Count}"/>
                            <Run Text="{DynamicResource Dup.FileCountSuffix}"/>
                        </TextBlock>
                    </StackPanel>
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type vmLocal:DuplicateItem}">
                    <StackPanel Orientation="Horizontal" Margin="2,2">
                        <CheckBox IsChecked="{Binding IsMarkedForDelete}" VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Path}" Foreground="{DynamicResource FgLightBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Size, Converter={StaticResource FileSize}}"
                                   Foreground="{DynamicResource FgMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding Note}" Foreground="{DynamicResource WarnBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>

        <!-- Row 3: Действия над отметками / Mark actions -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <WrapPanel Orientation="Horizontal">
                <Button Content="{DynamicResource Dup.MarkExceptFirst}"
                        Command="{Binding MarkExceptFirstCommand}"
                        Padding="12,5" Margin="0,0,8,4" Style="{DynamicResource DefaultButtonStyle}"/>
                <Button Content="{DynamicResource Dup.ClearMarks}"
                        Command="{Binding ClearMarksCommand}"
                        Padding="12,5" Margin="0,0,8,4" Style="{DynamicResource DefaultButtonStyle}"/>
                <Button Content="{DynamicResource Dup.DeleteMarked}"
                        Command="{Binding DeleteMarkedCommand}"
                        Padding="12,5" Margin="0,0,0,4" Style="{DynamicResource AccentButtonStyle}"/>
            </WrapPanel>
        </Border>

        <!-- Row 4: Статус + поиск / Status + search -->
        <Border Grid.Row="4" Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource FgDimBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <ProgressBar Value="{Binding ProgressPercent}" Width="160" Height="6" Margin="12,0,0,0"
                                 Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource BgDarkBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{DynamicResource Dup.Search}"
                            Command="{Binding SearchCommand}"
                            Padding="16,6" Margin="0,0,8,0" Style="{DynamicResource AccentButtonStyle}"/>
                    <Button Content="{DynamicResource Dup.Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="16,6" Style="{DynamicResource DefaultButtonStyle}"
                            Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
