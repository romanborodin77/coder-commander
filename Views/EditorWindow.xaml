<Window x:Class="CoderCommander.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:services="clr-namespace:CoderCommander.Services"
        Title="{DynamicResource Editor.Title}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Width="900" Height="600"
        MinWidth="400" MinHeight="300"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="6" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveActiveTabCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseActiveTabCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl+Shift" Command="{Binding CloseAllTabsCommand}"/>
        <KeyBinding Key="Tab" Modifiers="Ctrl" Command="{Binding NextTabCommand}"/>
        <KeyBinding Key="Tab" Modifiers="Ctrl+Shift" Command="{Binding PreviousTabCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="StatusBarItemStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="EditorTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{Binding Source={x:Static services:ThemeColors.BgHeaderBrush}}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding Source={x:Static services:ThemeColors.AccentBrush}}"/>
                                <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeColors.FgLightBrush}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{Binding Source={x:Static services:ThemeColors.SurfaceHoverBrush}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom TitleBar -->
        <Border Grid.Row="0" Height="36"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ModeIcon}"
                           Foreground="{DynamicResource FgLightBrush}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Margin="12,0,4,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           Foreground="{DynamicResource FgLightBrush}"
                           VerticalAlignment="Center"
                           FontSize="13"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="&#xE921;" ToolTip="{DynamicResource Editor.Tip.Minimize}" Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"/>
                    <Button x:Name="MaximizeButton" Content="&#xE922;" ToolTip="{DynamicResource Editor.Tip.Maximize}"
                            Click="MaximizeButton_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                    <Button Content="&#xE8BB;" ToolTip="{DynamicResource Editor.Tip.Close}" Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Content area — text editor with tabs / image viewer -->
        <Grid Grid.Row="1">
            <!-- Текстовый редактор с вкладками / Text editor with tabs -->
            <DockPanel x:Name="TextEditorDockPanel">
                <!-- Полоса вкладок + кнопка "+" / Tab strip + "+" button -->
                <Border DockPanel.Dock="Top" Height="28"
                        Background="{DynamicResource BgHeaderBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button x:Name="AddTabButton" DockPanel.Dock="Right"
                                Content="+" ToolTip="{DynamicResource Editor.Tab.New}"
                                Click="AddTab_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource FgDimBrush}"
                                FontSize="16" FontWeight="Bold"
                                Width="28" Height="28" Cursor="Hand"/>
                        <TabControl x:Name="EditorTabControl"
                                    Background="Transparent" BorderThickness="0"
                                    Height="28" VerticalAlignment="Top"
                                    SelectionChanged="EditorTabControl_SelectionChanged"
                                    MouseDown="EditorTabControl_MouseDown">
                            <TabControl.Template>
                                <ControlTemplate TargetType="TabControl">
                                    <TabPanel IsItemsHost="True" Background="Transparent"/>
                                </ControlTemplate>
                            </TabControl.Template>
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem" BasedOn="{StaticResource EditorTabItemStyle}">
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="{DynamicResource Editor.Tab.Close}"
                                                          Command="{Binding PlacementTarget.Tag.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="{DynamicResource Editor.Tab.CloseOthers}"
                                                          Command="{Binding PlacementTarget.Tag.CloseOtherTabsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="{DynamicResource Editor.Tab.CloseAll}"
                                                          Command="{Binding PlacementTarget.Tag.CloseAllTabsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.ItemContainerStyle>
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="✕"
                                                Width="16" Height="16"
                                                FontSize="8" Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource FgDimBrush}"
                                                Cursor="Hand"
                                                VerticalAlignment="Center"
                                                Margin="4,0,0,0"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding TabTitle}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="2,0,0,0"/>
                                    </DockPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>
                    </DockPanel>
                </Border>

                <!-- Область редактора / Editor content area -->
                <Border x:Name="TextEditorBorder"
                        Background="{DynamicResource VsEditorBg}">
                    <Grid x:Name="EditorContainer"/>
                </Border>
            </DockPanel>

            <!-- Просмотрщик изображений (скрыт по умолчанию) / Image viewer (hidden by default) -->
            <Border x:Name="ImageBorder"
                    Visibility="Collapsed"
                    Background="{DynamicResource BgDarkBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource BgHeaderBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="4,2">
                            <Button x:Name="BtnZoomIn" Click="ZoomIn_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource FgLightBrush}"
                                    FontSize="13" Padding="6,3" Margin="1,0"
                                    ToolTip="{DynamicResource Editor.Image.ZoomIn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="+" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnZoomOut" Click="ZoomOut_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource FgLightBrush}"
                                    FontSize="13" Padding="6,3" Margin="1,0"
                                    ToolTip="{DynamicResource Editor.Image.ZoomOut}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="-" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnZoomReset" Click="ZoomReset_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource FgLightBrush}"
                                    FontSize="12" Padding="6,3" Margin="1,0"
                                    Content="1:1" ToolTip="{DynamicResource Editor.Image.ZoomReset}"/>
                            <Button x:Name="BtnZoomFit" Click="ZoomFit_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource FgLightBrush}"
                                    FontSize="12" Padding="6,3" Margin="1,0"
                                    Content="{DynamicResource Editor.Image.Fit}" ToolTip="{DynamicResource Editor.Image.ZoomFit}"/>

                            <Border Width="1" Height="18" Background="{DynamicResource BorderBrush}" Margin="5,0"/>

                            <Button x:Name="BtnRotateLeft" Click="RotateLeft_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource FgLightBrush}"
                                    FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="6,3" Margin="1,0"
                                    Content="&#xE777;" ToolTip="{DynamicResource Editor.Image.RotateLeft}"/>
                            <Button x:Name="BtnRotateRight" Click="RotateRight_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource FgLightBrush}"
                                    FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="6,3" Margin="1,0"
                                    Content="&#xE776;" ToolTip="{DynamicResource Editor.Image.RotateRight}"/>

                            <Border Width="1" Height="18" Background="{DynamicResource BorderBrush}" Margin="5,0"/>

                            <Button x:Name="BtnSlideshow" Click="Slideshow_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource FgLightBrush}"
                                    FontFamily="Segoe MDL2 Assets" FontSize="14" Padding="6,3" Margin="1,0"
                                    Content="&#xE768;" ToolTip="{DynamicResource Editor.Image.Slideshow}"/>

                            <Border Width="1" Height="18" Background="{DynamicResource BorderBrush}" Margin="5,0"/>

                            <TextBlock x:Name="ZoomText" Text="100%"
                                       Foreground="{DynamicResource FgMutedBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="8,0"/>
                            <TextBlock x:Name="ImageInfoText"
                                       Foreground="{DynamicResource FgMutedBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{DynamicResource BgDarkBrush}">
                        <Image x:Name="ImageViewer"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: StatusBar -->
        <Border Grid.Row="2" Height="26"
                Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="{Binding ActiveTab.FilePathDisplay}"
                               Style="{StaticResource StatusBarItemStyle}"
                               ToolTip="{Binding ActiveTab.FilePath}"/>
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}"
                               Margin="8,0" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Style="{StaticResource StatusBarItemStyle}">
                        <Run Text="{Binding ActiveTab.LineCount, Mode=OneWay}"/><Run Text=" "/><Run Text="{DynamicResource Editor.Lines}"/>
                    </TextBlock>
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}"
                               Margin="8,0" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveTab.Encoding}" Style="{StaticResource StatusBarItemStyle}"/>
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}"
                               Margin="8,0" FontSize="11" VerticalAlignment="Center"
                               Visibility="{Binding ActiveTab.IsModified, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{DynamicResource Editor.Modified}"
                               Foreground="{DynamicResource WarnBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Visibility="{Binding ActiveTab.IsModified, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding ActiveTab.Language}"
                           Foreground="{DynamicResource FgMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
