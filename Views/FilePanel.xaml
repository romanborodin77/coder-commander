                              Style="{DynamicResource ContextMenuItemStyle}"/>
                    <MenuItem Header="{DynamicResource Ctx.ArchiveCreate}" Command="{Binding PackCommand}" Style="{DynamicResource ContextMenuItemStyle}"/>
                    <MenuItem Header="{DynamicResource Ctx.ArchiveExtract}" Command="{Binding ExtractCommand}" Style="{DynamicResource ContextMenuItemStyle}"/>
