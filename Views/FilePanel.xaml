            </ListBox.ContextMenu>

<!-- ItemTemplate генерируется динамически FilePanel.xaml.cs (RebuildColumns) -->
    <!-- ListBox.ItemTemplate будет установлен из code-behind -->

        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <!--
                    Курсор (SelectedItem/IsSelected) и метки (FileSystemItem.IsSelected) — независимы.
                    WPF Single mode tracks only cursor. Marks are shown via DataTrigger on FileSystemItem.IsSelected.
                    Cursor (SelectedItem/IsSelected) and marks (FileSystemItem.IsSelected) are independent.
                -->
                <Setter Property="MinHeight" Value="27"/>
                <Setter Property="Padding" Value="4,0"/>
                <Setter Property="Margin" Value="0,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AccentBar" Grid.Column="0"
                                        CornerRadius="2" Margin="2,4,0,4" Opacity="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="{Binding Color, Source={x:Static services:ThemeColors.AccentBrush}}" Offset="0"/>
                                            <GradientStop Color="{Binding Color, Source={x:Static services:ThemeColors.AccentSecondaryBrush}}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="Bd" Grid.Column="1"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        Padding="{TemplateBinding Padding}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <!-- Чередование строк (AlternationIndex=1) -->
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource RowAltBrush}"/>
                                </Trigger>
                                <!-- Метка (FileSystemItem.IsSelected=True): подсветка + акцент-бар -->
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{Binding Source={x:Static services:ThemeColors.SelectionBrush}}"/>
                                    <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                                </DataTrigger>
                                <!-- Курсор (ListBoxItem.IsSelected=True): рамка -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding Source={x:Static services:ThemeColors.AccentBrush}}"/>
                                </Trigger>
                                <!-- Курсор + фокус клавиатуры: яркая рамка -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding Source={x:Static services:ThemeColors.AccentSecondaryBrush}}"/>
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                </MultiTrigger>
                                <!-- Hover без метки -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsSelected" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="{Binding Source={x:Static services:ThemeColors.SurfaceHoverBrush}}"/>
                                </MultiTrigger>
                                <!-- Hover с меткой -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsSelected" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="{Binding Source={x:Static services:ThemeColors.SelectionActiveBrush}}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
    </ListBox.ItemContainerStyle>
    </ListBox>
    </Grid>
        <!-- ══════ Row 4: Status Line ══════ -->
        <Border Grid.Row="4"
                Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Height="24">
            <Grid Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Items count badge -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="5"
                        Padding="8,3"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Items, Converter={StaticResource ItemsCount}}"
                               FontSize="11" Foreground="{DynamicResource FgDimBrush}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Selected count + size -->
                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           FontSize="11"
                           VerticalAlignment="Center">
                    <Run Text="{Binding SelectedCount, Mode=OneWay}"
                         Foreground="{DynamicResource AccentBrush}"/>
                    <Run Text=" / " Foreground="{DynamicResource FgMutedBrush}"/>
                    <Run Text="{Binding SelectedSizeDisplay, Mode=OneWay}"
                         Foreground="{DynamicResource FgDimBrush}"/>
                </TextBlock>

                <!-- Cursor file info -->
                <TextBlock Grid.Column="2"
                           Text="{Binding CursorInfo}"
                           Foreground="{DynamicResource FgDimBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="12,0,0,0"/>

                <!-- Free space -->
                <TextBlock Grid.Column="3"
                           Text="{Binding FreeSpaceDisplay}"
                           Foreground="{DynamicResource FgMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <!-- Current path -->
                <TextBlock Grid.Column="4"
                           Text="{Binding CurrentPath}"
                           Foreground="{DynamicResource FgMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="200"
                           Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- ══════ Row 5: Active Panel Indicator ══════ -->
        <Border Grid.Row="5"
                Height="3"
                CornerRadius="1.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{Binding Color, Source={x:Static services:ThemeColors.AccentBrush}}" Offset="0"/>
                    <GradientStop Color="{Binding Color, Source={x:Static services:ThemeColors.AccentSecondaryBrush}}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <Binding Path="IsActive"/>
                            </DataTrigger.Binding>
                            <Setter Property="Opacity" Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.5"
                                  Color="{Binding Color, Source={x:Static services:ThemeColors.AccentBrush}}" Direction="90"/>
            </Border.Effect>
        </Border>
    </Grid>
</UserControl>
