<UserControl x:Class="CoderCommander.Views.GitPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CoderCommander.Converters"
             xmlns:s="clr-namespace:CoderCommander.Services">
    <UserControl.Resources/>

    <DockPanel>
        <!-- ============================== ТУЛБАР ============================== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgHeaderBrush}" Padding="8,4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{DynamicResource Git.Refresh}" ToolTip="{DynamicResource Git.Tip.Refresh}"
                            Command="{Binding RefreshCommand}" Style="{DynamicResource PanelToolbarBtnStyle}"/>
                    <Separator Width="1" Margin="4,2"/>
                    <Button Content="{DynamicResource Git.Fetch}" ToolTip="{DynamicResource Git.Tip.Fetch}"
                            Command="{Binding FetchCommand}" Margin="4,0,0,0" Style="{DynamicResource PanelToolbarBtnStyle}"/>
                    <Button Content="{DynamicResource Git.Pull}" ToolTip="{DynamicResource Git.Tip.Pull}"
                            Command="{Binding PullCommand}" Margin="4,0,0,0" Style="{DynamicResource PanelToolbarBtnStyle}"/>
                    <Button Content="{DynamicResource Git.Push}" ToolTip="{DynamicResource Git.Tip.Push}"
                            Command="{Binding PushCommand}" Margin="4,0,0,0" Style="{DynamicResource PanelToolbarBtnStyle}"/>
                    <Separator Width="1" Margin="4,2"/>
                    <Button Content="{DynamicResource Git.Stash}" ToolTip="{DynamicResource Git.Tip.Stash}"
                            Command="{Binding StashCommand}" Style="{DynamicResource PanelToolbarBtnStyle}"/>
                    <Button Content="{DynamicResource Git.PopStash}" ToolTip="{DynamicResource Git.Tip.PopStash}"
                            Command="{Binding PopStashCommand}" Margin="4,0,0,0" Style="{DynamicResource PanelToolbarBtnStyle}"/>
                    <Separator Width="1" Margin="4,2"/>
                    <Button Content="{DynamicResource Git.NewBranch}" ToolTip="{DynamicResource Git.Tip.NewBranch}"
                            Command="{Binding NewBranchCommand}" Style="{DynamicResource PanelToolbarBtnStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ============================== ИНДИКАТОР ЗАГРУЗКИ ============================== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgDarkBrush}" Height="3"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource AccentBrush}" HorizontalAlignment="Left" Width="50" Height="3">
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    From="-50,0,0,0" To="350,0,0,0"
                                                    Duration="0:0:1.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </Border>

    <!-- ============================== ИНФО О ВЕТКЕ ============================== -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource BgPanelBrush}" Padding="10,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Левая часть: ветка и счётчики -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Git.Branch}" Foreground="{DynamicResource FgDimBrush}"
                    VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                <ComboBox ItemsSource="{Binding Branches}"
                    SelectedItem="{Binding Branch, Mode=OneWay}"
                    Width="170"
                    SelectionChanged="Branch_Changed"
                    ToolTip="{DynamicResource Git.Tip.Branch}"/>
                <TextBlock Text="{Binding Ahead, StringFormat=' ↑{0}'}"
                    Foreground="{DynamicResource WarnBrush}" VerticalAlignment="Center" Margin="10,0,0,0"
                    ToolTip="{DynamicResource Git.Tip.Ahead}" FontWeight="SemiBold" FontSize="11"/>
                <TextBlock Text="{Binding Behind, StringFormat=' ↓{0}'}"
                    Foreground="{DynamicResource ErrBrush}" VerticalAlignment="Center" Margin="6,0,0,0"
                    ToolTip="{DynamicResource Git.Tip.Behind}" FontWeight="SemiBold" FontSize="11"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Foreground="{DynamicResource DiffAddBrush}" FontWeight="Bold" FontSize="11">+</TextBlock>
                    <TextBlock Text="{Binding StagedCount, Mode=OneWay}" Margin="2,0,8,0"
                        Foreground="{DynamicResource DiffAddBrush}" FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Foreground="{DynamicResource WarnBrush}" FontWeight="Bold" FontSize="11">~</TextBlock>
                    <TextBlock Text="{Binding UnstagedCount, Mode=OneWay}" Margin="2,0,0,0"
                        Foreground="{DynamicResource WarnBrush}" FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{DynamicResource Git.Changes}" Foreground="{DynamicResource FgDimBrush}" Margin="4,0,0,0" FontSize="11"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Правая часть: статус -->
            <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="{DynamicResource FgDimBrush}"
                VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="11"/>
        </Grid>
    </Border>

        <!-- ============================== КОММИТ-СЕКЦИЯ (нижняя панель) ============================== -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgHeaderBrush}" Padding="8,5">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Git.Commit}"
                        Command="{Binding CommitCommand}"
                        Margin="6,0,0,0"
                        Style="{DynamicResource PanelToolbarBtnStyle}"
                        FontWeight="SemiBold"/>
                <CheckBox DockPanel.Dock="Right"
                          Content="{DynamicResource Git.Amend}"
                          IsChecked="{Binding Amend}"
                          VerticalAlignment="Center"
                          Margin="10,0,0,0"
                          Foreground="{DynamicResource FgDimBrush}"
                          ToolTip="{DynamicResource Git.Tip.Amend}"/>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                        Background="{DynamicResource SurfaceDeepBrush}" VerticalAlignment="Stretch">
                    <Grid>
                        <TextBox x:Name="CommitTextBox"
                                 Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="Commit_KD"
                                 Height="56"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 VerticalContentAlignment="Top"
                                 Padding="6,4"
                                 BorderThickness="0"
                                 Background="Transparent"/>
                        <TextBlock Text="{DynamicResource Git.CommitMsgPlaceholder}"
                                   Foreground="{DynamicResource FgDimBrush}"
                                   IsHitTestVisible="False"
                                   FontStyle="Italic"
                                   Padding="8,6"
                                   FontSize="12"
                                   VerticalAlignment="Top"
                                   Visibility="{Binding Text.Length, ElementName=CommitTextBox,
                                        Converter={StaticResource LengthToVis}}"/>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>

        <!-- ============================== ОСНОВНАЯ ЗОНА: 3 КОЛОНКИ ============================== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== ПАНЕЛЬ ИЗМЕНЕНИЙ (Колонка 0) ===== -->
            <DockPanel Grid.Column="0">
                <Border Style="{DynamicResource SectionHeaderStyle}">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="+" ToolTip="{DynamicResource Git.Tip.StageAll}"
                                    Command="{Binding StageAllCommand}" Style="{DynamicResource PanelIconBtnStyle}"/>
                            <Button Content="−" ToolTip="{DynamicResource Git.Tip.UnstageAll}"
                                    Command="{Binding UnstageAllCommand}" Margin="4,0,0,0" Style="{DynamicResource PanelIconBtnStyle}"/>
                            <Button Content="✎" ToolTip="{DynamicResource Git.Tip.OpenDiff}"
                                    Command="{Binding OpenDiffInEditorCommand}" Margin="4,0,0,0" Style="{DynamicResource PanelIconBtnStyle}"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Git.ChangesTitle}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                    </DockPanel>
                </Border>

                <!-- Состояние: не репозиторий -->
                <Border Visibility="{Binding IsRepo, Converter={StaticResource BoolToVisInv}}"
                        Background="{DynamicResource BgPanelBrush}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⊘" FontSize="48" Foreground="{DynamicResource FgDimBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Git.NoRepo}" Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Состояние: нет изменений (поверх списка, скрывается когда список непуст) -->
                <Border Background="Transparent"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsRepo}" Value="True"/>
                                        <Condition Binding="{Binding Files.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="✓" FontSize="36" Foreground="{DynamicResource DiffAddBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Git.NoChanges}" Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="14" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Git.NoUntracked}" Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Список файлов с изменениями -->
                <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"
                         Background="{DynamicResource BgPanelBrush}" BorderThickness="0"
                         MouseDoubleClick="File_Dbl">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="2,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка состояния (цветная буква на полупрозрачном фоне) -->
                                    <Border Grid.Column="0"
                                            Width="20" Height="20"
                                            CornerRadius="3"
                                            VerticalAlignment="Center"
                                            Background="{Binding State, Converter={StaticResource GitStateBrush}}"
                                            Opacity="0.15">
                                        <TextBlock Text="{Binding StateShort}"
                                                   Foreground="{Binding State, Converter={StaticResource GitStateBrush}}"
                                                   FontWeight="Bold" FontFamily="Consolas"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Opacity="1.0"/>
                                    </Border>

                                    <!-- Имя файла -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Path}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Margin="6,0,0,0"/>

                                    <!-- Компактные кнопки действий -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0,0,0">
                                        <Button Content="+" ToolTip="{DynamicResource Git.Tip.Stage}"
                                                Command="{Binding DataContext.StageCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                Style="{DynamicResource PanelIconBtnStyle}"/>
                                        <Button Content="−" ToolTip="{DynamicResource Git.Tip.Unstage}"
                                                Command="{Binding DataContext.UnstageCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                Style="{DynamicResource PanelIconBtnStyle}"/>
                                        <Button Content="✎" ToolTip="{DynamicResource Git.Tip.OpenEditor}"
                                                Command="{Binding DataContext.OpenInEditorCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                Style="{DynamicResource PanelIconBtnStyle}"/>
                                        <Button Content="↺" ToolTip="{DynamicResource Git.Tip.Discard}"
                                                Command="{Binding DataContext.DiscardCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                Style="{DynamicResource PanelIconBtnStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Разделитель 1 -->
            <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- ===== ПАНЕЛЬ DIFF (Колонка 1) ===== -->
            <DockPanel Grid.Column="2">
                <Border Style="{DynamicResource SectionHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DiffTitle}" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" FontFamily="Consolas" FontSize="12"/>
                        <Button Grid.Column="1" Content="◉" ToolTip="{DynamicResource Git.Tip.OpenDiff}"
                                Command="{Binding OpenDiffInEditorCommand}"
                                Style="{DynamicResource PanelIconBtnStyle}" Margin="6,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Подсказка при пустом diff -->
                <TextBlock Text="{DynamicResource Git.SelectFileHint}"
                           Foreground="{DynamicResource FgDimBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" FontStyle="Italic"
                           Visibility="{Binding DiffLines.Count, Converter={StaticResource LengthToVis}}"/>

                <!-- Строки diff с фоновой подсветкой добавленных/удалённых -->
                <ScrollViewer Background="{DynamicResource BgPanelBrush}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DiffLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,0,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                 <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.Added}">
                                                     <Setter Property="Background" Value="{DynamicResource DiffAddBrush}"/>
                                                 </DataTrigger>
                                                 <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.Removed}">
                                                     <Setter Property="Background" Value="{DynamicResource DiffDelBrush}"/>
                                                 </DataTrigger>
                                                 <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.Hunk}">
                                                     <Setter Property="Background" Value="{DynamicResource DiffHunkBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="NoWrap"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Padding="8,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.Added}">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffAddBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.Removed}">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffDelBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.Hunk}">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffHunkBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.Meta}">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffMetaBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static s:DiffLineKind.File}">
                                                        <Setter Property="Foreground" Value="{DynamicResource DiffFileBrush}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- Разделитель 2 -->
            <GridSplitter Grid.Column="3" Width="4" Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- ===== ПАНЕЛЬ ИСТОРИИ (Колонка 2) ===== -->
            <DockPanel Grid.Column="4">
                <Border Style="{DynamicResource SectionHeaderStyle}">
                    <TextBlock Text="{DynamicResource Git.CommitHistory}" FontWeight="SemiBold" FontSize="13"/>
                </Border>

                <!-- История коммитов -->
                <ListBox ItemsSource="{Binding Log}" SelectedItem="{Binding SelectedCommit}"
                         Background="{DynamicResource BgPanelBrush}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,5" Margin="0,1" CornerRadius="4"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Украшенный хэш коммита -->
                                    <Border Grid.Row="0" Grid.Column="0"
                                            Background="{DynamicResource AccentDimBrush}"
                                            CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ShortHash}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                    </Border>

                                    <!-- Тема коммита -->
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Subject}"
                                               TextTrimming="CharacterEllipsis"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>

                                    <!-- Относительное время -->
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="{Binding RelativeDate}"
                                               Foreground="{DynamicResource FgDimBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>

                                    <!-- Автор -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                               Foreground="{DynamicResource FgDimBrush}"
                                               FontSize="11"
                                               Margin="0,3,0,0">
                                        <Run Text="{Binding Author}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
