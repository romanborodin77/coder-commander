<Window x:Class="CoderCommander.Views.MacroManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CoderCommander.Models"
        Title="{DynamicResource Macro.Title}"
        Width="720" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent">

    <!-- Явный WindowChrome с CaptionHeight=0.
         При AllowsTransparency=True унаследованный глобальный шаблон (CaptionHeight=32)
         помечал ВСЁ окно как неклиентскую область. Нулевая высота caption делает
         всё окно клиентской областью → все элементы кликабельны.
         Explicit WindowChrome with CaptionHeight=0.
         With AllowsTransparency=True the inherited global chrome marked the WHOLE
         window as non-client. A zero caption height makes the entire window clickable. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="6" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <!-- Ctrl+N — новый макрос / New macro -->
        <KeyBinding Gesture="Ctrl+N" Command="{Binding AddMacroCommand}"/>
        <!-- Delete — удалить макрос / Delete macro -->
        <KeyBinding Gesture="Delete" Command="{Binding DeleteMacroCommand}"/>
        <!-- F5 — выполнить макрос / Execute macro -->
        <KeyBinding Gesture="F5" Command="{Binding ExecuteMacroCommand}"/>
    </Window.InputBindings>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
            Background="{DynamicResource BgDarkBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <!-- Панель заголовка / Title bar -->
            <Border Grid.Row="0" Height="36" Background="{DynamicResource TitleBarBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="{DynamicResource Macro.Title}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgLightBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Width="36" Height="36"
                            HorizontalAlignment="Right"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- ═══ Main Content ═══ -->
            <!-- Основное содержимое / Main content -->
            <Grid Grid.Row="1" Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель: список макросов / Left panel: macro list -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Поиск / Search -->
                    <TextBox Grid.Row="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12" Padding="6,5" Margin="0,0,0,6"
                             Background="{DynamicResource BgHeaderBrush}"
                             Foreground="{DynamicResource FgLightBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"/>

                    <!-- Список макросов / Macro list -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Macros}"
                             SelectedItem="{Binding SelectedMacro}"
                             Background="Transparent"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource BorderBrush}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MacroItem}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource FgLightBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Hotkey}" FontSize="10"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontFamily="Consolas"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="{DynamicResource FgMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Правая панель: детали макроса / Right panel: macro details -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Имя / Name -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Macro.Name}" FontSize="12"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding SelectedMacro.Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Padding="6,4"
                                 Background="{DynamicResource BgHeaderBrush}"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"/>
                    </Grid>

                    <!-- Описание / Description -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Macro.Description}" FontSize="12"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding SelectedMacro.Description, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Padding="6,4"
                                 Background="{DynamicResource BgHeaderBrush}"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"/>
                    </Grid>

                    <!-- Горячая клавиша + Включен / Hotkey + Enabled -->
                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Macro.Hotkey}" FontSize="12"
                                   Foreground="{DynamicResource FgLightBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding SelectedMacro.Hotkey, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Padding="6,4"
                                 FontFamily="Consolas"
                                 Background="{DynamicResource BgHeaderBrush}"
                                 Foreground="{DynamicResource FgLightBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"/>
                        <TextBlock Grid.Column="2" Text="{DynamicResource Macro.Enabled}" FontSize="11"
                                   Foreground="{DynamicResource FgMutedBrush}"
                                   VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <CheckBox Grid.Column="3" IsChecked="{Binding SelectedMacro.IsEnabled}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Заголовок шагов / Steps header -->
                    <TextBlock Grid.Row="3" Text="{DynamicResource Macro.Steps}" FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource FgLightBrush}"
                               Margin="0,4,0,4"/>

                    <!-- Список шагов / Steps list -->
                    <DataGrid Grid.Row="4"
                              ItemsSource="{Binding SelectedMacro.Steps}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderBrush}"
                              HeadersVisibility="Column"
                              x:Name="StepsGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Order}" Width="36" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{DynamicResource Macro.ColCommand}" Binding="{Binding CommandName}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{DynamicResource Macro.ColParams}" Binding="{Binding ParamsDisplay}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <!-- Кнопки управления шагами / Step control buttons -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="{DynamicResource Macro.AddStep}" Padding="10,5" FontSize="11"
                                Command="{Binding AddStepCommand}"
                                Background="{DynamicResource BgHeaderBrush}"
                                Foreground="{DynamicResource FgLightBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button Content="{DynamicResource Macro.RemoveStep}" Padding="10,5" FontSize="11"
                                Margin="6,0,0,0"
                                Command="{Binding RemoveStepCommand}"
                                CommandParameter="{Binding SelectedItem, ElementName=StepsGrid}"
                                Background="{DynamicResource BgHeaderBrush}"
                                Foreground="{DynamicResource FgLightBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button Content="&#xE73A;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                Padding="8,5" Margin="6,0,0,0"
                                ToolTip="{DynamicResource Macro.MoveUp}"
                                Command="{Binding MoveStepUpCommand}"
                                CommandParameter="{Binding SelectedItem, ElementName=StepsGrid}"
                                Background="{DynamicResource BgHeaderBrush}"
                                Foreground="{DynamicResource FgLightBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button Content="&#xE73B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                Padding="8,5" Margin="6,0,0,0"
                                ToolTip="{DynamicResource Macro.MoveDown}"
                                Command="{Binding MoveStepDownCommand}"
                                CommandParameter="{Binding SelectedItem, ElementName=StepsGrid}"
                                Background="{DynamicResource BgHeaderBrush}"
                                Foreground="{DynamicResource FgLightBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ═══ Bottom Buttons ═══ -->
            <!-- Нижние кнопки / Bottom buttons -->
            <Border Grid.Row="2" Background="{DynamicResource BgHeaderBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource Macro.Execute}" Padding="14,7" Margin="0,0,8,0"
                            Command="{Binding ExecuteMacroCommand}"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Content="{DynamicResource Macro.Cancel}" Padding="14,7" Margin="0,0,8,0"
                            Click="Cancel_Click"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Content="{DynamicResource Macro.Save}" Padding="14,7" FontWeight="SemiBold"
                            Click="Save_Click"
                            Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
