<Window x:Class="CoderCommander.Views.MultiRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CoderCommander.ViewModels"
        mc:Ignorable="mc"
        Title="{DynamicResource MultiRename.Title}"
        Width="760" Height="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}"
        Foreground="{DynamicResource FgLightBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="6" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="CaretBrush" Value="{DynamicResource FgLightBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок / Title bar -->
        <Border Grid.Row="0" Height="36"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource MultiRename.Title}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="{DynamicResource FgLightBrush}" FontWeight="SemiBold"/>
                <Button Grid.Column="1" Width="36" Height="36"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- Контент / Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="14">
            <StackPanel>
                <!-- Режим / Mode -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton Content="{DynamicResource MultiRename.ModeMask}"
                                 IsChecked="{Binding UseRegexMode, Converter={StaticResource BoolToVisInv}, Mode=OneWay}"
                                 Checked="ModeMask_Checked" GroupName="Mode" Margin="0,0,16,0"
                                 Foreground="{DynamicResource FgLightBrush}"/>
                    <RadioButton Content="{DynamicResource MultiRename.ModeRegex}"
                                 IsChecked="{Binding UseRegexMode, Mode=OneWay}"
                                 Checked="ModeRegex_Checked" GroupName="Mode"
                                 Foreground="{DynamicResource FgLightBrush}"/>
                </StackPanel>

                <!-- Маска / Mask -->
                <StackPanel Visibility="{Binding UseRegexMode, Converter={StaticResource BoolToVisInv}}">
                    <TextBlock Text="{DynamicResource MultiRename.Mask}" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Mask, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                    <TextBlock Text="{DynamicResource MultiRename.MaskHint}"
                               Foreground="{DynamicResource FgMutedBrush}" FontSize="11" Margin="0,4,0,8"
                               TextWrapping="Wrap" MaxWidth="700"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource MultiRename.CounterStart}" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource FgMutedBrush}"/>
                        <TextBox Grid.Column="1" Text="{Binding CounterStart, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                        <TextBlock Grid.Column="2" Text="{DynamicResource MultiRename.CounterStep}" VerticalAlignment="Center" Margin="10,0,6,0" Foreground="{DynamicResource FgMutedBrush}"/>
                        <TextBox Grid.Column="3" Text="{Binding CounterStep, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                        <TextBlock Grid.Column="4" Text="{DynamicResource MultiRename.CounterWidth}" VerticalAlignment="Center" Margin="10,0,6,0" Foreground="{DynamicResource FgMutedBrush}"/>
                        <TextBox Grid.Column="5" Text="{Binding CounterWidth, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                    </Grid>

                    <!-- Стиль имени / Name style -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource MultiRename.NameStyle}" VerticalAlignment="Center"
                                   Margin="0,0,8,0" Foreground="{DynamicResource FgMutedBrush}"/>
                        <ComboBox ItemsSource="{Binding NameStyles}" SelectedIndex="{Binding SelectedNameStyle}"
                                  Width="140" Background="{DynamicResource BgPanelBrush}"
                                  Foreground="{DynamicResource FgLightBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>

                    <!-- Запрещённые символы / Bad char replacement -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource MultiRename.BadChar}" VerticalAlignment="Center"
                                   Margin="0,0,8,0" Foreground="{DynamicResource FgMutedBrush}"/>
                        <TextBox Text="{Binding BadCharReplacement, UpdateSourceTrigger=PropertyChanged}"
                                 Width="40" Style="{StaticResource FieldBox}"/>
                        <TextBlock Text="{DynamicResource MultiRename.BadCharTip}" VerticalAlignment="Center"
                                   Margin="10,0,0,0" Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Регекс / Regex find-replace -->
                <StackPanel Visibility="{Binding UseRegexMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource MultiRename.Find}" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FindPattern, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                    <TextBlock Text="{DynamicResource MultiRename.Replace}" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding ReplacePattern, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                    <CheckBox Content="{DynamicResource MultiRename.CaseSensitive}"
                              IsChecked="{Binding CaseSensitive}" Margin="0,8,0,8"
                              Foreground="{DynamicResource FgLightBrush}"/>
                </StackPanel>

                <!-- Переменные [V:name] -->
                <StackPanel Visibility="{Binding HasVariables, Converter={StaticResource BoolToVis}}" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource MultiRename.Variables}" Style="{StaticResource FieldLabel}"/>
                    <ItemsControl ItemsSource="{Binding Variables}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource FgMutedBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FieldBox}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Пресеты / Presets -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource MultiRename.Preset}" VerticalAlignment="Center"
                               Margin="0,0,8,0" Foreground="{DynamicResource FgMutedBrush}"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding PresetNames}" SelectedItem="{Binding SelectedPreset}"
                              Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource FgLightBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"/>
                    <Button Grid.Column="2" Content="{DynamicResource MultiRename.PresetSave}" Command="{Binding SavePresetCommand}"
                            Style="{DynamicResource AccentButtonStyle}" Margin="8,0,0,0" Padding="10,4"/>
                    <Button Grid.Column="3" Content="{DynamicResource MultiRename.PresetLoad}" Command="{Binding LoadPresetCommand}"
                            Margin="6,0,0,0" Padding="10,4" Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Grid.Column="4" Content="{DynamicResource MultiRename.PresetDelete}" Command="{Binding DeletePresetCommand}"
                            Margin="6,0,0,0" Padding="10,4" Style="{DynamicResource DefaultButtonStyle}"/>
                </Grid>

                <!-- Логирование / Logging -->
                <StackPanel Margin="0,0,0,10">
                    <CheckBox Content="{DynamicResource MultiRename.EnableLog}"
                              IsChecked="{Binding EnableLogging}" Margin="0,0,0,6"
                              Foreground="{DynamicResource FgLightBrush}"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding EnableLogging, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource MultiRename.LogPath}" VerticalAlignment="Center"
                                   Margin="0,0,8,0" Foreground="{DynamicResource FgMutedBrush}"/>
                        <TextBox Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}" Width="320"/>
                    </StackPanel>
                </StackPanel>

                <!-- Предпросмотр / Preview -->
                <TextBlock Text="{DynamicResource MultiRename.Preview}" Style="{StaticResource FieldLabel}"/>
                <DataGrid ItemsSource="{Binding Items}" Height="200"
                          AutoGenerateColumns="False" HeadersVisibility="Column"
                          IsReadOnly="True" GridLinesVisibility="None"
                          Background="{DynamicResource BgPanelBrush}"
                          Foreground="{DynamicResource FgLightBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          RowBackground="{DynamicResource BgPanelBrush}"
                          AlternationCount="2"
                          AlternatingRowBackground="{DynamicResource SurfaceDeepBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource MultiRename.ColOriginal}" Binding="{Binding OriginalName}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{DynamicResource MultiRename.ColNew}" Binding="{Binding NewName}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>

        <!-- Статус + кнопки / Status + buttons -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource BgHeaderBrush}">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Status}" VerticalAlignment="Center"
                           Foreground="{DynamicResource FgMutedBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{DynamicResource MultiRename.Apply}" Command="{Binding ApplyCommand}"
                            Style="{DynamicResource AccentButtonStyle}" Padding="14,6" IsDefault="True"/>
                    <Button Content="{DynamicResource Dialog.Cancel}" Click="CancelButton_Click"
                            Padding="14,6" Margin="8,0,0,0" IsCancel="True" Style="{DynamicResource DefaultButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
