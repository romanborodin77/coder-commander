<Window x:Class="CoderCommander.Views.OpenWithWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource OpenWith.Title}"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/> <!-- Titlebar -->
            <RowDefinition Height="*"/>  <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══ Custom Title Bar ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                    <Border Width="20" Height="20"
                            Background="{DynamicResource AccentDimBrush}"
                            CornerRadius="5" Margin="0,0,10,0">
                        <TextBlock Text="&#xE7AC;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource OpenWith.Title}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgLightBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Center: draggable -->
                <Grid Grid.Column="1" Background="Transparent"/>

                <!-- Right: close button -->
                <Button Grid.Column="2"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Content ═══ -->
        <Grid Grid.Row="1" Margin="16,12,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- File name -->
                <RowDefinition Height="8"/>    <!-- Spacer -->
                <RowDefinition Height="*"/>    <!-- App list -->
                <RowDefinition Height="8"/>    <!-- Spacer -->
                <RowDefinition Height="Auto"/> <!-- Options -->
            </Grid.RowDefinitions>

            <!-- File name -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8" Padding="12,10">
                <TextBlock Text="{Binding SelectedFile}"
                           Foreground="{DynamicResource FgLightBrush}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- Application list -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8" Padding="4">
                <ListBox ItemsSource="{Binding AvailableApps}"
                         SelectedItem="{Binding SelectedApp}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Margin" Value="2,2"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="{Binding Icon}"
                                       Width="20" Height="20"
                                       Margin="0,0,10,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="{DynamicResource FgLightBrush}"/>
                                    <TextBlock Text="{Binding Path}"
                                               FontSize="10"
                                               Foreground="{DynamicResource FgMutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="380"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Options -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal">
                <CheckBox Content="{DynamicResource OpenWith.SetDefault}"
                          IsChecked="{Binding SetAsDefault}"
                          Foreground="{DynamicResource FgDimBrush}"
                          FontSize="12"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"/>
                <Button Content="{DynamicResource OpenWith.Browse}"
                        Command="{Binding BrowseForAppCommand}"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        FontSize="12"
                        Padding="12,4"
                        Width="Auto" MinWidth="100"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Footer ═══ -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{DynamicResource OpenWith.Open}"
                        Command="{Binding OpenWithSelectedCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        IsDefault="True"
                        Style="{DynamicResource ToolbarAccentStyle}"
                        FontSize="12"
                        Padding="16,6"
                        Width="Auto" MinWidth="100"
                        Margin="0,0,8,0"/>
                <Button Content="{DynamicResource OpenWith.Cancel}"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        IsCancel="True"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        FontSize="12"
                        Padding="16,6"
                        Width="Auto" MinWidth="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
