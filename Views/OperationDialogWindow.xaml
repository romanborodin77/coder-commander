<Window x:Class="CoderCommander.Views.OperationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding OperationTitle}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Width="560" Height="380"
        MinWidth="460" MinHeight="320"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom TitleBar -->
        <Border Grid.Row="0" Height="36"
                Background="{DynamicResource TitleBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="&#xE8F1;"
                           FontFamily="Segoe MDL2 Assets" FontSize="15"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,6,0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding OperationTitle}"
                           Foreground="{DynamicResource FgLightBrush}"
                           VerticalAlignment="Center"
                           FontSize="13"/>
                <Button Grid.Column="2" Content="&#xE8BB;"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Row 1: Content -->
        <Grid Grid.Row="1" Margin="24,20,24,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Source → Dest -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding SourcePath, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding SourcePath}"/>
                <TextBlock Grid.Column="1" Text="  →  "
                           Foreground="{DynamicResource AccentBrush}" FontSize="12"
                           FontWeight="Bold" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding DestPath, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding DestPath}"/>
            </Grid>

            <!-- Current file label -->
            <TextBlock Grid.Row="2" FontSize="11"
                       Foreground="{DynamicResource FgDimBrush}">
                <Run Text="{Binding CurrentFile, Mode=OneWay, StringFormat='{}{0}'}"/>
            </TextBlock>

            <!-- File ProgressBar -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Minimum="0" Maximum="100"
                             Value="{Binding FileProgress, Mode=OneWay}"
                             Height="6" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Margin="10,0,0,0"
                           Text="{Binding FileProgress, StringFormat={}{0:0}%, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                           VerticalAlignment="Center" MinWidth="42" TextAlignment="Right"/>
            </Grid>

            <!-- Overall ProgressBar -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Minimum="0" Maximum="100"
                             Value="{Binding OverallProgress, Mode=OneWay}"
                             Height="6" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Margin="10,0,0,0"
                           Text="{Binding OverallProgress, StringFormat={}{0:0}%, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                           VerticalAlignment="Center" MinWidth="42" TextAlignment="Right"/>
            </Grid>

            <!-- Stats row: Speed + ETA + Files -->
            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource OpDlg.Speed}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding SpeedText}"
                           Foreground="{DynamicResource FgLightBrush}" FontSize="11"
                           Margin="4,0,16,0"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource OpDlg.ETA}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"/>
                <TextBlock Grid.Column="3" Text="{Binding EtaText}"
                           Foreground="{DynamicResource FgLightBrush}" FontSize="11"
                           Margin="4,0,16,0"/>
                <TextBlock Grid.Column="4" Text="{Binding FilesText}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"/>
            </Grid>

            <!-- State text -->
            <TextBlock Grid.Row="12"
                       Text="{Binding StateText}"
                       Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                       FontStyle="Italic" Margin="0,4,0,0"/>
        </Grid>

        <!-- Row 2: Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding OperationTitle}"
                           Foreground="{DynamicResource FgMutedBrush}" FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{Binding PauseButtonText}"
                            Command="{Binding TogglePauseCommand}"
                            Margin="0,0,8,0" Padding="14,7" FontSize="13"
                            Style="{DynamicResource DefaultButtonStyle}"
                            IsEnabled="{Binding IsComplete, Converter={StaticResource BoolToVisInv}}"/>
                    <Button Content="{DynamicResource OpDlg.Skip}"
                            Command="{Binding SkipCommand}"
                            Margin="0,0,8,0" Padding="14,7" FontSize="13"
                            Style="{DynamicResource DefaultButtonStyle}"
                            IsEnabled="{Binding IsComplete, Converter={StaticResource BoolToVisInv}}"/>
                    <Button Content="{DynamicResource OpDlg.Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="14,7" FontSize="13"
                            Style="{DynamicResource DefaultButtonStyle}"
                            Foreground="{DynamicResource ErrBrush}"
                            IsEnabled="{Binding IsComplete, Converter={StaticResource BoolToVisInv}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
