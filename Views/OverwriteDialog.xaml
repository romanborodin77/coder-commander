<Window x:Class="CoderCommander.Views.OverwriteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource OpDlg.Overwrite.Title}"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Width="650" Height="320"
        MinWidth="550" MinHeight="280"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgDarkBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0"
                      ResizeBorderThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding AbortCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom TitleBar -->
        <Border Grid.Row="0" Height="36"
                Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource OpDlg.Overwrite.Title}"
                           Foreground="{DynamicResource FgLightBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="13"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="&#xE8BB;" Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Content -->
        <Grid Grid.Row="1" Margin="20,12,20,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- File name -->
            <TextBlock Grid.Row="0" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource FgLightBrush}">
                <Run Text="{Binding FileName, Mode=OneWay}"/>
            </TextBlock>

            <!-- Source label -->
            <TextBlock Grid.Row="2" Text="{DynamicResource OpDlg.Overwrite.Source}"
                       Foreground="{DynamicResource AccentBrush}" FontSize="12"
                       FontWeight="SemiBold"/>

            <!-- Source path -->
            <TextBlock Grid.Row="4" Text="{Binding SourceInfo, Mode=OneWay}"
                       Foreground="{DynamicResource FgLightBrush}" FontSize="12"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Source size + date -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding SourceSizeInfo, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding SourceDateInfo, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- Dest label -->
            <TextBlock Grid.Row="8" Text="{DynamicResource OpDlg.Overwrite.Dest}"
                       Foreground="{DynamicResource ErrBrush}" FontSize="12"
                       FontWeight="SemiBold"/>

            <!-- Dest path -->
            <TextBlock Grid.Row="10" Text="{Binding DestInfo, Mode=OneWay}"
                       Foreground="{DynamicResource FgLightBrush}" FontSize="12"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Dest size + date -->
            <Grid Grid.Row="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding DestSizeInfo, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding DestDateInfo, Mode=OneWay}"
                           Foreground="{DynamicResource FgDimBrush}" FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Grid>

        <!-- Row 2: Buttons + Apply to all -->
        <Border Grid.Row="2" Background="{DynamicResource BgHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Apply to all checkbox (left) -->
                <CheckBox Grid.Column="0" Content="{DynamicResource OpDlg.Overwrite.ApplyAll}"
                          IsChecked="{Binding ApplyToAll, Mode=TwoWay}"
                          Foreground="{DynamicResource FgDimBrush}" FontSize="12"
                          VerticalAlignment="Center"/>
                
                <!-- Buttons (right, all in one row) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{DynamicResource OpDlg.Overwrite.Skip}"
                            Command="{Binding SkipCommand}" Margin="0,0,4,0"
                            Padding="10,5" FontSize="12"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Content="{DynamicResource OpDlg.Overwrite.SkipAll}"
                            Command="{Binding SkipAllCommand}" Margin="0,0,4,0"
                            Padding="10,5" FontSize="12"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Content="{DynamicResource OpDlg.Overwrite.Overwrite}"
                            Command="{Binding OverwriteCommand}" Margin="0,0,4,0"
                            Padding="10,5" FontSize="12" FontWeight="SemiBold"
                            Style="{DynamicResource AccentButtonStyle}"/>
                    <Button Content="{DynamicResource OpDlg.Overwrite.OverwriteAll}"
                            Command="{Binding OverwriteAllCommand}" Margin="0,0,4,0"
                            Padding="10,5" FontSize="12"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Content="{DynamicResource OpDlg.Overwrite.Older}"
                            Command="{Binding OverwriteOlderCommand}" Margin="0,0,4,0"
                            Padding="10,5" FontSize="12"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Content="{DynamicResource OpDlg.Overwrite.Rename}"
                            Command="{Binding AutoRenameCommand}" Margin="0,0,4,0"
                            Padding="10,5" FontSize="12"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                    <Button Content="{DynamicResource OpDlg.Overwrite.Abort}"
                            Command="{Binding AbortCommand}"
                            Padding="10,5" FontSize="12"
                            Style="{DynamicResource DefaultButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
