<Window x:Class="CoderCommander.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings.Title}"
        Width="540" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgDarkBrush}"
        WindowStyle="None"
        AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Ультра-компактные стили -->
        <Style x:Key="CompactTabItem" TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="CompactRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="CompactLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CompactGroupHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>

        <Style x:Key="CompactSeparator" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        <Style x:Key="CompactCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="140"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="CompactSmallCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="72"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="CompactCheck" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Height="32" Background="{DynamicResource TitleBarBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="{DynamicResource Settings.Title}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgLightBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Width="32" Height="32"
                            HorizontalAlignment="Right"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Row="1" BorderThickness="0" Margin="6,6,6,0">

                <!-- ═══════════ Appearance ═══════════ -->
                <TabItem Style="{StaticResource CompactTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Settings.Appearance}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                        <StackPanel>
                            <!-- Язык + Тема -->
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.Appearance}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.Language}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}" SelectedIndex="{Binding LanguageIndex}">
                                    <ComboBoxItem Content="English"/>
                                    <ComboBoxItem Content="Русский"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.Theme}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}" SelectedIndex="{Binding ThemeIndex}">
                                    <ComboBoxItem Content="{DynamicResource Settings.Theme.Dark}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.Theme.Light}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.Theme.System}"/>
                                </ComboBox>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <!-- Files -->
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.Files}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowHidden}" Content="{DynamicResource Settings.ShowHidden}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding SortFoldersFirst}" Content="{DynamicResource Settings.SortFoldersFirst}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowFileSize}" Content="{DynamicResource Settings.ShowFileSizeLabel}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowModificationDate}" Content="{DynamicResource Settings.ShowDateLabel}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowFileAttributes}" Content="{DynamicResource Settings.ShowAttributesLabel}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowFullPathInTitle}" Content="{DynamicResource Settings.ShowPathInTitle}"/>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <!-- Window opacity -->
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.WindowOpacity}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="100%"/>
                                    <ComboBoxItem Content="95%"/>
                                    <ComboBoxItem Content="90%"/>
                                    <ComboBoxItem Content="85%"/>
                                    <ComboBoxItem Content="80%"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ Editor ═══════════ -->
                <TabItem Style="{StaticResource CompactTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE104;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Settings.Editor}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                        <StackPanel>
                            <!-- Font -->
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionFont}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.EditorFont}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}"
                                          SelectedValue="{Binding EditorFontFamily}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="Cascadia Code"/>
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="JetBrains Mono"/>
                                    <ComboBoxItem Content="Fira Code"/>
                                    <ComboBoxItem Content="Source Code Pro"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.EditorFontSize}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="{Binding EditorFontSizeIndex}">
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="13"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="15"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="18"/>
                                    <ComboBoxItem Content="20"/>
                                </ComboBox>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <!-- Display -->
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionDisplay}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorShowLineNumbers}" Content="{DynamicResource Settings.LineNumbers}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorWordWrap}" Content="{DynamicResource Settings.WordWrap}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorHighlightCurrentLine}" Content="{DynamicResource Settings.EditorHighlightCurrentLine}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorHighlightBrackets}" Content="{DynamicResource Settings.EditorHighlightBrackets}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorShowColumnRuler}" Content="{DynamicResource Settings.ColumnRuler}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorAutoCloseBrackets}" Content="{DynamicResource Settings.EditorAutoCloseBrackets}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorAutoCloseQuotes}" Content="{DynamicResource Settings.EditorAutoCloseQuotes}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorShowSpaces}" Content="{DynamicResource Settings.ShowSpaces}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorShowTabs}" Content="{DynamicResource Settings.ShowTabs}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorShowEndOfLine}" Content="{DynamicResource Settings.ShowEndOfLine}"/>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <!-- Indentation -->
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionIndent}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.Width}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="{Binding EditorTabWidthIndex}">
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="8"/>
                                </ComboBox>
                                <CheckBox Grid.Column="2" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding EditorUseSpaces}" Content="{DynamicResource Settings.UseSpaces}" Margin="12,0,0,0"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="12,0,0,0"
                                            IsEnabled="{Binding EditorShowColumnRuler}">
                                    <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.RulerPosition}" Margin="0,0,4,0"/>
                                    <ComboBox Style="{StaticResource CompactSmallCombo}"
                                              SelectedValue="{Binding EditorColumnRulerPosition}" SelectedValuePath="Content">
                                        <ComboBoxItem Content="60"/>
                                        <ComboBoxItem Content="80"/>
                                        <ComboBoxItem Content="100"/>
                                        <ComboBoxItem Content="120"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <!-- Highlighting -->
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.EditorMinHighlightLength}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}"
                                          SelectedIndex="{Binding EditorMinHighlightLength}">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ Terminal ══════════ -->
                <TabItem Style="{StaticResource CompactTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Settings.Terminal}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionShell}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.DefaultShell}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}" SelectedIndex="{Binding TerminalShellIndex}">
                                    <ComboBoxItem Content="cmd"/>
                                    <ComboBoxItem Content="PowerShell"/>
                                </ComboBox>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionFont}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.TerminalFont}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}"
                                          SelectedValue="{Binding TerminalFontFamily}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="Cascadia Code"/>
                                    <ComboBoxItem Content="Lucida Console"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.TerminalFontSize}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="{Binding TerminalFontSizeIndex}">
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="16"/>
                                </ComboBox>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionBehavior}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.TerminalHeight}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="1">
                                    <ComboBoxItem Content="200"/>
                                    <ComboBoxItem Content="300"/>
                                    <ComboBoxItem Content="400"/>
                                    <ComboBoxItem Content="500"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.ScrollbackLines}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="1">
                                    <ComboBoxItem Content="5000"/>
                                    <ComboBoxItem Content="9999"/>
                                    <ComboBoxItem Content="50000"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.Cursor}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}" SelectedIndex="{Binding TerminalCursorStyleIndex}">
                                    <ComboBoxItem Content="{DynamicResource Settings.CursorBlock}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.CursorUnderline}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.CursorBar}"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ Panels ═══════════ -->
                <TabItem Style="{StaticResource CompactTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Settings.Panels}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionFont}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.PanelFont}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}"
                                          SelectedValue="{Binding PanelFontFamily}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="Segoe UI Variable, Segoe UI"/>
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="Cascadia Code"/>
                                    <ComboBoxItem Content="JetBrains Mono"/>
                                    <ComboBoxItem Content="Fira Code"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.PanelFontSize}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="{Binding PanelFontSizeIndex}">
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="13"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="15"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="17"/>
                                </ComboBox>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.SectionBehavior}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowDirectoryTree}" Content="{DynamicResource Settings.DirectoryTree}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding DoubleClickOpenFolder}" Content="{DynamicResource Settings.DoubleClick}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowHiddenFolders}" Content="{DynamicResource Settings.HiddenFolders}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowPathInPanelTitle}" Content="{DynamicResource Settings.ShowPathInTitle}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ShowFullPathsInPanels}" Content="{DynamicResource Settings.FullPaths}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding RememberLastPaths}" Content="{DynamicResource Settings.RememberPaths}"/>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.AutoRefresh}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}" SelectedIndex="{Binding AutoRefreshIntervalIndex}">
                                    <ComboBoxItem Content="1000 {DynamicResource Settings.Ms}"/>
                                    <ComboBoxItem Content="2000 {DynamicResource Settings.Ms}"/>
                                    <ComboBoxItem Content="3000 {DynamicResource Settings.Ms}"/>
                                    <ComboBoxItem Content="5000 {DynamicResource Settings.Ms}"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding AutoRefresh}" Content="{DynamicResource Settings.AutoRefreshCheck}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding DoubleClickOpenFile}" Content="{DynamicResource Settings.DoubleClickFile}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ File Operations ══════════ -->
                <TabItem Style="{StaticResource CompactTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Settings.FileOps}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.Overwrite}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.DefaultOverwrite}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactCombo}" SelectedIndex="{Binding DefaultOverwritePolicyIndex}">
                                    <ComboBoxItem Content="{DynamicResource Settings.OverwriteAsk}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.OverwriteAlways}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.OverwriteNever}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.OverwriteOlder}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.OverwriteSmaller}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings.OverwriteAutoRename}"/>
                                </ComboBox>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.BufferSize}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="{Binding BufferSizeIndex}">
                                    <ComboBoxItem Content="256"/>
                                    <ComboBoxItem Content="512"/>
                                    <ComboBoxItem Content="1024"/>
                                    <ComboBoxItem Content="2048"/>
                                    <ComboBoxItem Content="4096"/>
                                </ComboBox>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.Copying}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding CopyAttributes}" Content="{DynamicResource Settings.CopyAttributesLabel}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding CopyTimestamps}" Content="{DynamicResource Settings.CopyTimestampsLabel}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ReserveDiskSpace}" Content="{DynamicResource Settings.ReserveSpaceLabel}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding VerifyAfterCopy}" Content="{DynamicResource Settings.VerifyAfterCopy}"/>
                            </Grid>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding AbortOnError}" Content="{DynamicResource Settings.AbortOnError}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding AutoShowQueue}" Content="{DynamicResource Settings.AutoShowQueue}"/>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <TextBlock Style="{StaticResource CompactGroupHeader}" Text="{DynamicResource Settings.Confirmation}"/>
                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ConfirmDelete}" Content="{DynamicResource Settings.ConfirmDeleteLabel}"/>
                                <CheckBox Grid.Column="1" Style="{StaticResource CompactCheck}"
                                          IsChecked="{Binding ConfirmOverwrite}" Content="{DynamicResource Settings.ConfirmOverwriteLabel}"/>
                            </Grid>

                            <Border Style="{StaticResource CompactSeparator}"/>

                            <Grid Style="{StaticResource CompactRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource CompactLabel}" Text="{DynamicResource Settings.MaxRecursion}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource CompactSmallCombo}" SelectedIndex="1">
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="50"/>
                                    <ComboBoxItem Content="100"/>
                                    <ComboBoxItem Content="999"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ Hotkeys ══════════ -->
                <TabItem Style="{StaticResource CompactTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Settings.Hotkeys}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="8,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding HotkeysVM.Hotkeys}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HeadersVisibility="Column"
                                  CanUserSortColumns="False"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Hotkey.Action}" Binding="{Binding Action}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Margin" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{DynamicResource Hotkey.Key}" Binding="{Binding DisplayGesture}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Margin" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{DynamicResource Hotkey.Description}" Binding="{Binding Description}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Margin" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{DynamicResource Hotkey.Change}"
                                                    Padding="6,2" FontSize="11"
                                                    Background="{DynamicResource BgHeaderBrush}"
                                                    Foreground="{DynamicResource FgLightBrush}"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    Tag="{Binding}"
                                                    Click="HotkeyChange_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource FgLightBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                        <Border Grid.Row="1" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="{DynamicResource Hotkey.Reset}" Padding="10,4" FontSize="11"
                                        Background="{DynamicResource BgHeaderBrush}"
                                        Foreground="{DynamicResource FgLightBrush}"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        Click="HotkeyReset_Click"/>
                                <TextBlock x:Name="HotkeyStatusText"
                                           Text="" FontSize="11"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Bottom Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource BgHeaderBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource Settings.Reset}" Padding="12,5" Margin="0,0,6,0"
                            Click="Reset_Click" ToolTip="{DynamicResource Settings.ResetConfirm}"
                            Style="{DynamicResource DefaultButtonStyle}" FontSize="12"/>
                    <Button Content="{DynamicResource Settings.Save}" Padding="12,5" FontWeight="SemiBold"
                            Click="Save_Click" Style="{StaticResource AccentButtonStyle}" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
