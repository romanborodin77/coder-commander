<UserControl x:Class="CoderCommander.Views.SftpPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CoderCommander.Converters">
    <UserControl.Resources>
        <Style x:Key="SftpBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Основное содержимое -->
        <DockPanel>
            <!-- ===== Панель подключения ===== -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource BgHeaderBrush}" Padding="8,4">
                <DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <!-- Выбор профиля -->
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name"
                                  Width="200"
                                  ToolTip="{DynamicResource Sftp.Tip.SelectProfile}"/>
                        <!-- Кнопка подключения/отключения -->
                        <Button x:Name="ConnectBtn"
                                Command="{Binding ConnectCommand}"
                                Margin="4,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SftpBtn}">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8CD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Sftp.Connect}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8CD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource Sftp.Reconnect}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Индикатор подключения -->
                        <Ellipse Width="10" Height="10" Margin="6,0,0,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource FgDimBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource OkBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <Separator Style="{DynamicResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="6,2"/>

                        <!-- Кнопки действий -->
                        <Button Content="{DynamicResource Sftp.Refresh}" Command="{Binding RefreshCommand}"
                                Margin="4,0,0,0" Style="{StaticResource SftpBtn}"
                                ToolTip="{DynamicResource Sftp.Tip.Refresh}"/>
                        <Button Content="{DynamicResource Sftp.Download}" Command="{Binding DownloadToCommand}"
                                Style="{StaticResource SftpBtn}"
                                ToolTip="{DynamicResource Sftp.Tip.Download}"/>
                        <Button Content="{DynamicResource Sftp.Upload}" Command="{Binding UploadFromCommand}"
                                Margin="4,0,0,0" Style="{StaticResource SftpBtn}"
                                ToolTip="{DynamicResource Sftp.Tip.Upload}"/>
                        <Button Content="{DynamicResource Sftp.NewFolder}" Command="{Binding MakeDirCommand}"
                                Margin="4,0,0,0" Style="{StaticResource SftpBtn}"
                                ToolTip="{DynamicResource Sftp.Tip.NewFolder}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== Строка пути ===== -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource BgPanelBrush}" Padding="8,5">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="{DynamicResource Sftp.Up}"
                            Command="{Binding GoUpCommand}"
                            Margin="6,0,0,0" Style="{StaticResource SftpBtn}"
                            ToolTip="{DynamicResource Sftp.Tip.Up}"/>
                    <TextBlock Text="{DynamicResource Sftp.Path}"
                               Foreground="{DynamicResource FgDimBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox Text="{Binding CurrentRemotePath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ===== Список файлов ===== -->
            <ListBox ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     Background="{DynamicResource BgPanelBrush}"
                     BorderThickness="0"
                     MouseDoubleClick="Item_Dbl"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <!-- Иконка типа (папка/файл) -->
                            <TextBlock Grid.Column="0"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="15"
                                        VerticalAlignment="Center"
                                        Text="{Binding IsDirectory, Converter={StaticResource BoolToIcon}}"/>

                            <!-- Имя файла -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{Binding IsDirectory, Converter={StaticResource DirColor}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Размер (человекочитаемый) -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Size, Converter={StaticResource FileSize}}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       TextAlignment="Right"
                                       Margin="0,0,8,0"/>

                            <!-- Дата изменения -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding LastWriteTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       FontSize="11"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.OpenItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Sftp.Ctx.Open}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource Sftp.Ctx.Download}"
                                              Command="{Binding PlacementTarget.Tag.DownloadToCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Sftp.Ctx.Rename}"
                                              Command="{Binding PlacementTarget.Tag.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}"/>
                                    <MenuItem Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Sftp.Ctx.Delete}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Sftp.Ctx.NewFolder}"
                                              Command="{Binding PlacementTarget.Tag.MakeDirCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Style="{DynamicResource ContextMenuItemStyle}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- ===== Нижняя панель статуса ===== -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource BgHeaderBrush}"
                    Padding="8,4">
                <DockPanel>
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource FgDimBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource OkBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Status}"
                               Foreground="{DynamicResource FgLightBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- ===== Оверлей загрузки ===== -->
        <Border Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource BgHeaderBrush}"
                    CornerRadius="8" Padding="24,16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Sftp.Loading}"
                               Foreground="{DynamicResource FgLightBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
