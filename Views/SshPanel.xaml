<UserControl x:Class="CoderCommander.Views.SshPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- ===== Верхняя панель инструментов ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgHeaderBrush}" Padding="8,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- Группа: Профили -->
                    <Button Content="{DynamicResource Ssh.New}" Command="{Binding NewProfileCommand}"
                            ToolTip="{DynamicResource Ssh.Tip.New}"/>
                    <Button Command="{Binding SaveProfileCommand}"
                            Margin="4,0,0,0" ToolTip="{DynamicResource Ssh.Tip.Save}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Ssh.Save}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteProfileCommand}"
                            Margin="4,0,0,0" ToolTip="{DynamicResource Ssh.Tip.Delete}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Ssh.Delete}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Style="{DynamicResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="6,2"/>

                    <!-- Группа: Действия -->
                    <Button ToolTip="{DynamicResource Ssh.Tip.Check}" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8CD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Ssh.CheckConnection}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== Основная область ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Левая панель: список профилей ===== -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource BgHeaderBrush}"
                        Padding="8,6">
                    <TextBlock Text="{DynamicResource Ssh.Profiles}" FontWeight="SemiBold" FontSize="13"/>
                </Border>

                <Grid>
                    <ListBox ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             Background="{DynamicResource BgPanelBrush}"
                             BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Название и адрес профиля -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource FgLightBrush}"/>
                                        <TextBlock Text="{Binding ScpTarget}"
                                                   Foreground="{DynamicResource FgDimBrush}"
                                                   FontSize="11"/>
                                    </StackPanel>

                                    <!-- Кнопки редактирования -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="✎"
                                                FontSize="10" Width="22" Height="22" Padding="0"
                                                Command="{Binding DataContext.EditProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource Ssh.Tip.Edit}"/>
                                        <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                FontSize="12" Width="22" Height="22" Padding="0"
                                                Margin="2,0,0,0"
                                                Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource Ssh.Tip.Delete}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Пустое состояние: нет профилей -->
                    <TextBlock Text="{DynamicResource Ssh.NoProfiles}"
                               Foreground="{DynamicResource FgDimBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="20">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Profiles.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <!-- Разделитель колонок -->
            <GridSplitter Grid.Column="1" Width="6"
                          Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"/>

            <!-- ===== Правая панель: форма редактирования ===== -->
            <ScrollViewer Grid.Column="2"
                          Margin="12,8" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Ssh.Editor}"
                               FontSize="15" FontWeight="SemiBold"
                               Margin="0,0,0,14"
                               Foreground="{DynamicResource FgLightBrush}"/>

                    <!-- Поле: Имя -->
                    <Label Content="{DynamicResource Ssh.ProfileName}" Padding="0,0,0,2" Foreground="{DynamicResource FgDimBrush}"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <!-- Поле: Хост -->
                    <Label Content="{DynamicResource Ssh.Host}" Padding="0,0,0,2" Foreground="{DynamicResource FgDimBrush}"/>
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <!-- Поле: Пользователь -->
                    <Label Content="{DynamicResource Ssh.User}" Padding="0,0,0,2" Foreground="{DynamicResource FgDimBrush}"/>
                    <TextBox Text="{Binding User, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <!-- Поле: Порт -->
                    <Label Content="{DynamicResource Ssh.Port}" Padding="0,0,0,2" Foreground="{DynamicResource FgDimBrush}"/>
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <!-- Поле: Удалённый путь -->
                    <Label Content="{DynamicResource Ssh.RemotePath}" Padding="0,0,0,2" Foreground="{DynamicResource FgDimBrush}"/>
                    <TextBox Text="{Binding RemotePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <!-- Поле: Приватный ключ -->
                    <Label Content="{DynamicResource Ssh.IdentityFile}"
                           Padding="0,0,0,2" Foreground="{DynamicResource FgDimBrush}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SelectedProfile.IdentityFile, Mode=OneWay}"
                                 ToolTip="{DynamicResource Ssh.Tip.Key}"
                                 IsReadOnly="True"
                                 Foreground="{DynamicResource FgDimBrush}"/>
                        <Button Grid.Column="1" Content="⋯" Width="28"
                                Margin="4,0,0,0"
                                ToolTip="{DynamicResource Ssh.Tip.KeyFile}"/>
                    </Grid>

                    <!-- Подсказка по публикации -->
                    <Label Content="{DynamicResource Ssh.Publish}" Padding="0,0,0,2"
                           Foreground="{DynamicResource FgDimBrush}" Margin="0,8,0,0"/>
                    <Border Background="{DynamicResource BgPanelBrush}"
                            CornerRadius="4" Padding="10,8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <TextBlock Text="{DynamicResource Ssh.PublishHint}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource FgDimBrush}"
                                   FontSize="11"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===== Нижняя панель статуса ===== -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgHeaderBrush}"
                Padding="8,4">
            <DockPanel>
                <Ellipse Width="8" Height="8"
                         Fill="{DynamicResource FgDimBrush}"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Status}"
                           Foreground="{DynamicResource FgLightBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
