<Window x:Class="CoderCommander.Views.StyledMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Title="{DynamicResource MsgBox.Message}"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Background="{DynamicResource BgDarkBrush}" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TitleBar -->
            <Border Grid.Row="0" Height="36"
                    Background="{DynamicResource TitleBarBgBrush}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="TitleText" Text="{DynamicResource MsgBox.Message}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgLightBrush}"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <Button Width="36" Height="36" HorizontalAlignment="Right"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,12,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Border x:Name="IconBorder" Grid.Column="0" Width="40" Height="40"
                        CornerRadius="10" VerticalAlignment="Top" Margin="0,4,16,0"
                        Background="{DynamicResource AccentDimBrush}">
                    <TextBlock x:Name="IconText" Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Message -->
                <TextBlock x:Name="MessageText" Grid.Column="1"
                           TextWrapping="Wrap" FontSize="13"
                           Foreground="{DynamicResource FgLightBrush}"
                           VerticalAlignment="Center"
                           LineHeight="20"/>
            </Grid>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource BgHeaderBrush}"
                    CornerRadius="0,0,10,10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10">
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                            HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
